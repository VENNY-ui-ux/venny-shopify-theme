{% for item in cart.items %}
  {% assign has_compare = false %}
  {% if item.original_price > item.final_price %}
    {% assign has_compare = true %}
  {% endif %}

  <article class="CartDrawerItem"
           data-cart-item
           data-line="{{ forloop.index }}">
    <div class="CartDrawerItem__ImageWrapper">
      <a href="{{ item.url }}">
        {% if item.image %}
          <img
            src="{{ item.image | img_url: '160x' }}"
            alt="{{ item.image.alt | escape }}"
            class="CartDrawerItem__Image">
        {% else %}
          <div class="CartDrawerItem__Image CartDrawerItem__Image--placeholder"></div>
        {% endif %}
      </a>
    </div>

    <div class="CartDrawerItem__Content">
      <div class="CartDrawerItem__TopRow">
        <div class="CartDrawerItem__TitleBlock">
          <a href="{{ item.url }}" class="CartDrawerItem__Title">
            {{ item.product.title }}
          </a>
          {% unless item.variant.title == 'Default Title' %}
            <div class="CartDrawerItem__Meta">{{ item.variant.title }}</div>
          {% endif %}

          {% if item.selling_plan_allocation != blank %}
            <div class="CartDrawerItem__Meta">{{ item.selling_plan_allocation.selling_plan.name }}</div>
          {% endif %}
        </div>

        <button
          type="button"
          class="CartDrawerItem__Remove"
          data-cart-remove
          aria-label="Remove {{ item.product.title }}"
          data-line="{{ forloop.index }}">
          ×
          <span class="VisuallyHidden">{{ 'cart.items.remove' | t }}</span>
        </button>
      </div>

      <div class="CartDrawerItem__BottomRow">
        <div class="CartDrawerItem__Qty">
          <button type="button"
                  class="CartDrawerItem__QtyBtn"
                  data-cart-qty-minus
                  data-line="{{ forloop.index }}"
                  aria-label="{{ 'general.accessibility.minus' | t }}">-</button>

          <input
            type="number"
            class="CartDrawerItem__QtyInput"
            value="{{ item.quantity }}"
            min="1"
            inputmode="numeric"
            data-cart-qty-input
            aria-label="{{ 'product.form.quantity' | t }}"
            data-line="{{ forloop.index }}">

          <button type="button"
                  class="CartDrawerItem__QtyBtn"
                  data-cart-qty-plus
                  data-line="{{ forloop.index }}"
                  aria-label="{{ 'general.accessibility.plus' | t }}">+</button>
        </div>

        <div class="CartDrawerItem__PriceGroup">
          <div class="CartDrawerItem__Price">{{ item.final_line_price | money }}</div>
          {% if has_compare %}
            <div class="CartDrawerItem__ComparePrice">{{ item.original_line_price | money }}</div>
          {% endif %}
        </div>
      </div>

      {% if item.line_level_discount_allocations.size > 0 %}
        <ul class="CartDrawerItem__Discounts" role="list">
          {% for discount_allocation in item.line_level_discount_allocations %}
            <li class="CartDrawerItem__Discount">{{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})</li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </article>
{% endfor %}
