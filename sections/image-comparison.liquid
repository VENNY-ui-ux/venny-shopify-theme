{{ 'section-image-comparison.css' | asset_url | stylesheet_tag }}
{% liquid 
  assign section_image_ratio = 2.2
  if section.settings.after_image != blank
    assign section_image_ratio = section.settings.after_image.aspect_ratio
  elsif section.settings.before_image != blank
    assign section_image_ratio = section.settings.before_image.aspect_ratio
  endif 

  assign section_image_ratio_mobile = 1
  if section.settings.after_image_mobile != blank
    assign section_image_ratio_mobile = section.settings.after_image_mobile.aspect_ratio
  elsif section.settings.before_image_mobile != blank
    assign section_image_ratio_mobile = section.settings.before_image_mobile.aspect_ratio
  elsif section.settings.after_image != blank or section.settings.before_image != blank
    assign section_image_ratio_mobile = section_image_ratio
  endif 

  assign lazy_load = 'lazy'
  if section.index == 1 and section.location != 'footer'
    assign lazy_load = 'eager'
  endif
-%}
<style>
  #section-{{ section.id }}{
    --section-image-comparison-cursor-position: {{ section.settings.cursor_initial_position }}%;
    --section-image-comparison-cursor-button: {{ section.settings.cursor_initial_position }}%;
    --section-image-comparison-cursor-background-color: {{ section.settings.cursor_background_color }};
    --section-image-comparison-cursor-arrows-color: {{ section.settings.cursor_arrows_color }};

    --section-image-comparison-before-text-color: {{ section.settings.before_image_label_color }};
    --section-image-comparison-after-text-color: {{ section.settings.after_image_label_color }};
  }

  @media screen and (max-width: 640px) {
    #section-{{ section.id }} .ImageComparison__Body{
      --tg-aspect-ratio: {{ section_image_ratio_mobile }};
    }
  }
  @media screen and (min-width: 641px) {
    #section-{{ section.id }} .ImageComparison__Body{
      --tg-aspect-ratio: {{ section_image_ratio }};
    }
  }
</style>

{%- capture before_image_label -%}
  {%- if section.settings.before_image_label != blank -%}
    <span class="ImageComparison__Label ImageComparison__Label--foreground">{{ section.settings.before_image_label }}</span>
  {%- endif -%}
{%- endcapture -%}

{%- capture after_image_label -%}
  {%- if section.settings.after_image_label != blank -%}
    <span class="ImageComparison__Label ImageComparison__Label--background">{{ section.settings.after_image_label }}</span>
  {%- endif -%}
{%- endcapture -%}

<script src="{{ 'section-image-comparison.js' | asset_url }}" defer="defer"></script>
<image-comparison data-cursor-direction="{{ section.settings.cursor_direction }}" class="Container Container--specialSpacingFirstSection ImageComparison ImageComparison--{{ section.settings.section_width }} ImageComparison--{{ section.settings.cursor_direction }} {% if section.settings.section_width == 'full_width' %}Container--fluid Container--spacingContainerGutter Container--specialSpacingLastSection{% elsif section.settings.section_width ==  'full_width_no_gap' %}Container--fluid Container--noGutter Container--specialSpacingLastSection{% else %}Container--{{ section.settings.section_spacing }}{% endif %}"
   id="section-{{ section.id }}" data-section-id="{{ section.id }}">

  {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.button_label != blank -%}
    <header class="SectionHeader {% if section.settings.section_width == 'full_width_no_gap' %}SectionHeader--withContainerNoGutter{% endif %} SectionHeader--{{ section.settings.header_align }}">
      <div class="SectionHeader__Text">
        {%- if section.settings.heading != blank -%}
            <h2 class="SectionHeader__Heading CustomSize {{ section.settings.heading_font_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
            <div class="SectionHeader__Subheading TextMuted">{{ section.settings.subheading }} </div>
        {%- endif -%}
      </div>

      {%- if section.settings.header_align == 'left' and section.settings.button_label != blank -%} 
        <div class="SectionHeader__Button"> 
          <a href="{{ section.settings.button_link }}" class="SectionHeader__Button Button Button--outline">{{ section.settings.button_label | escape }}</a>        
        </div>
      {%- endif -%}
    </header>
  {%- endif -%}

  
  <div class="SectionBody ImageComparison__Body Ratio">
    <!-- Mobile -->
    {%- if section.settings.before_image_mobile != blank -%}
      <div class="ImageComparison__Foreground Ratio HiddenMediumUp">
        {{ section.settings.before_image_mobile | image_url: width: 1500 | image_tag:
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500',
          class: 'ImageComparison__Image',
          loading: lazy_load
        }}
      </div>
    {%- endif -%}

    <!-- Desktop -->
    {%- if section.settings.before_image != blank -%}
      <div class="ImageComparison__Foreground Ratio {% if section.settings.before_image_mobile != blank %} HiddenSmall{% endif %}">
        {{ section.settings.before_image | image_url: width: 3840 | image_tag:
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          class: 'ImageComparison__Image',
          loading: lazy_load
        }}
      </div>
    {%- else -%}
      <div class="ImageComparison__Foreground Ratio {% if section.settings.before_image_mobile != blank %} HiddenSmall{% endif %}">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'ImageComparison__Image SvgPlaceholder' }}
      </div>
    {%- endif -%}

    {{ before_image_label }}

     <!-- Mobile -->
     {%- if section.settings.after_image_mobile != blank -%}
      <div class="ImageComparison__Background Ratio HiddenMediumUp">
        {{ section.settings.after_image_mobile | image_url: width: 1500 | image_tag:
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500',
          class: 'ImageComparison__Image',
          loading: lazy_load
        }}

        {{ after_image_label }}
      </div>
    {%- endif -%}

    <!-- Desktop -->
    {%- if section.settings.after_image != blank -%}
      <div class="ImageComparison__Background Ratio {% if section.settings.after_image_mobile != blank %} HiddenSmall{% endif %}">
        {{ section.settings.after_image | image_url: width: 3840 | image_tag:
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          class: 'ImageComparison__Image',
          loading: lazy_load
        }}
        {{ after_image_label }}
      </div>
    {%- else -%}
      <div class="ImageComparison__Background Ratio {% if section.settings.after_image_mobile != blank %} HiddenSmall{% endif %}">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'ImageComparison__Image SvgPlaceholder' }}
        {{ after_image_label }}
      </div>
    {%- endif -%}

    <input type="range" min="0" max="100" value="{{ section.settings.cursor_initial_position }}" class="ImageComparison__Cursor" name="ImageComparisonCursor">
    <div class="ImageComparison__CursorButton">{%- render 'icons', icon: 'code' -%}</div>
  </div>

  {%- if section.settings.header_align == 'center' and section.settings.button_label != blank -%} 
    <footer class="SectionFooter {% if section.settings.section_width == 'full_width_no_gap' %}SectionHeader--withContainerNoGutter{% endif %} TextCenter">
        <a class="SectionFooter__Button Button Button--outline" href="{{ collection.url }}">{{ section.settings.button_label | escape }}</a>
    </footer>
  {%- endif -%}
</image-comparison>
{% schema %}
{
  "name": "Before/after image",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "default",
          "label": "Grid"
        },
        {
          "value": "full_width",
          "label": "Full width"
        },
        {
          "value": "full_width_no_gap",
          "label": "Full width no gap"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "Section spacing",
      "options": [
        {
          "value": "spacingSmall",
          "label": "Small"
        },
        {
          "value": "spacingMedium",
          "label": "Medium"
        },
        {
          "value": "spacingLarge",
          "label": "Large"
        }
      ],
      "default": "spacingMedium",
      "info": "Visible when the ‘Section width’ setting is set to Grid."
    },
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Before/after"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header alignment",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading size",
      "options": [
        {
          "value": "HeadlineSmall",
          "label": "Small"
        },
        {
          "value": "HeadlineMedium",
          "label": "Medium"
        },
        {
          "value": "HeadlineLarge",
          "label": "Large"
        }
      ],
      "default": "HeadlineMedium"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View details"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Cursor"
    },
    {
      "type": "select",
      "id": "cursor_direction",
      "label": "Direction",
      "options": [
        {
          "value": "horizontal",
          "label": "Horizontal"
        },
        {
          "value": "vertical",
          "label": "Vertical"
        }
      ],
      "default": "horizontal"
    },
    {
      "type": "range",
      "id": "cursor_initial_position",
      "label": "Initial position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "color",
      "id": "cursor_background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cursor_arrows_color",
      "label": "Arrows",
      "default": "#1c1b1b"
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "text",
      "id": "before_image_label",
      "label": "Before text",
      "default": "Before"
    },
    {
      "type": "color",
      "id": "before_image_label_color",
      "label": "Before text color",
      "default": "#1c1b1b"
    },
    {
      "type": "text",
      "id": "after_image_label",
      "label": "After text",
      "default": "After"
    },
    {
      "type": "color",
      "id": "after_image_label_color",
      "label": "After text color",
      "default": "#1c1b1b"
    },
    {
      "type": "header",
      "content": "Image desktop"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image",
      "info": "2400 x 1200px .jpg recommended."
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image",
      "info": "2400 x 1200px .jpg recommended."
    },
    {
      "type": "header",
      "content": "Image mobile"
    },
    {
      "type": "image_picker",
      "id": "before_image_mobile",
      "label": "Before image",
      "info": "1200 x 1200px .jpg recommended."
    },
    {
      "type": "image_picker",
      "id": "after_image_mobile",
      "label": "After image",
      "info": "1200 x 1200px .jpg recommended."
    }
  ],
  "presets": [
    {
      "name": "Before/after image",
      "settings": {
      }
    }
  ]
}
{% endschema %}