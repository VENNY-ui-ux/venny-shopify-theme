{%- capture carousel_options -%}
  {
    "freeMode": true,
    "slidesPerView": "auto",
    "navigation": {
      "enabled": false,
      "nextEl": ".Carousel__NavNext",
      "prevEl": ".Carousel__NavPrev"
    },
    "pagination": {
      "enabled": {% if section.blocks.size > 1 %}true{% else %}false{% endif %},
      "el": ".Carousel__Pagination",
      "clickable": true
    },
    "autoplay": {
      "enabled": {% if section.settings.autoplay and section.blocks.size > 1 %}true{% else %}false{% endif %},
      "delay": {{ section.settings.cycle_speed | times: 1000 }},
      "disableOnInteraction": false,
      "pauseOnMouseEnter": true
    },
    "breakpoints": {
      "640": {
        "slidesPerView": "auto",
        "freeMode": false,
        "navigation": {
          "enabled": {% if section.blocks.size > 1 %}true{% else %}false{% endif %},
          "nextEl": ".Carousel__NavNext",
          "prevEl": ".Carousel__NavPrev"
        },
        "pagination": {
          "enabled": false,
          "el": ".Carousel__Pagination",
          "clickable": true
        }
      }
    }
  }
{%- endcapture -%}

{{ 'component-carousel.css' | asset_url | stylesheet_tag }}
{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_testimonial_block = false
  assign has_background_image = false
  assign slide_index0 = 0
  for block in section.blocks
    case block.type
      when 'testimonial'
        assign has_testimonial_block = true
      when 'background_image'
        assign has_background_image = true
        assign background_image = block.settings.image
        assign background_image_block_attributes = block.shopify_attributes
    endcase
  endfor 
-%}

<style>
  {%- if section.settings.background_color != blank -%}
    {%- unless has_background_image -%}
    #section-{{ section.id }}{
      background-color:{{ section.settings.background_color }};
    }
    {%- endunless -%}
  {%- endif -%}
  
  {%- if section.settings.quote_background != blank -%}
    #section-{{ section.id }} .Testimonial:not(.Testimonial--center) .Testimonial__Content {
      background-color: {{ section.settings.quote_background }};
      padding: 16px 20px;
    }
  
    #section-{{ section.id }} .Testimonial.Testimonial--center {
      background-color: {{ section.settings.quote_background }};
      padding: 50px 30px 30px;
    }
  
    #section-{{ section.id }} .Testimonial.Testimonial--border {
      box-shadow: 0 0 0 2px {{ section.settings.quote_background }} inset;
    }
  
    #section-{{ section.id }} .Testimonial .Testimonial__Content::after  {
      background-color: {{ section.settings.quote_background }};
    }
  {%- endif -%}
  {%- if section.settings.name_color != blank -%}
    #section-{{ section.id }} .Testimonial .Testimonial__AuthorName {
      color: {{ section.settings.name_color }};
    }
  {%- endif -%}
  {%- if section.settings.position_color != blank -%}
    #section-{{ section.id }} .Testimonial .Testimonial__AuthorPosition  {
      color: {{ section.settings.position_color }};
    }
  {%- endif -%}
  {%- if section.settings.quote_color != blank -%}
    #section-{{ section.id }} .Testimonial .Testimonial__Content {
      color: {{ section.settings.quote_color }};
    }
    #section-{{ section.id }} .Testimonial .Testimonial__Content a  {
      color: {{ section.settings.quote_color }};
      text-decoration-color: {{ section.settings.quote_color }};
    }
  {%- endif -%}
</style>


<script src="{{ 'section-testimonials.js' | asset_url }}" defer="defer"></script>
<section-testimonials class="Container Container--specialSpacingFirstSection Container--fluid Container--noGutter {% if has_background_image or section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}Container--specialSpacingLastSection Container--{{ section.settings.section_spacing }}Padding{% else %}Container--{{ section.settings.section_spacing }}{% endif %} Testimonials" id="section-{{ section.id }}" data-section-id="{{ section.id }}">
  {%- if has_background_image -%}
    {%- if background_image -%}
      <div class="Testimonials__BackgroundImageWrapper" {{ background_image_block_attributes }}>
        <div class="Testimonials__BackgroundImage"
          style="background-image: -webkit-image-set(
            url({{ background_image | image_url: width: 750 }}) 1x,
            url({{ background_image | image_url: width: 1500 }}) 2x);
          background-image:image-set(
            url({{ background_image | image_url: width: 750 }}) 1x,
            url({{ background_image | image_url: width: 1500 }}) 2x);">
        </div>
        <div class="BackgroundOverlay"></div>
      </div>
    {%- else -%}
      <div class="Testimonials__BackgroundImageWrapper" {{ background_image_block_attributes }}>
        {{ 'lifestyle-1' | placeholder_svg_tag: 'Testimonials__BackgroundImage SvgPlaceholder' }}
      </div>
    {%- endif -%}
  {%- endif -%}
{% comment %} add Container--relative to fixed bg index issue {% endcomment %}
  <div class="Container Container--relative">

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'section_header' -%}
          <header class="SectionHeader{% if block.settings.header_align == 'center' %} SectionHeader--center{% endif %} Testimonials__Header" {{ block.shopify_attributes }}>
            <div class="SectionHeader__Text">
              {%- if block.settings.heading != blank -%}
                  <h2 class="SectionHeader__Heading CustomSize {{ block.settings.heading_font_size }}" style="color: {{ block.settings.text_color }}">{{ block.settings.heading }}</h2>
              {%- endif -%}

              {%- if block.settings.subheading != blank -%}
                  <div class="SectionHeader__Subheading" style="color: {{ block.settings.text_color }}">{{ block.settings.subheading }} </div>
              {%- endif -%}
            </div>
          </header>

      {%- endcase -%}
    {%- endfor -%}

    <div class="Testimonials__Body Carousel" data-carousel-config='{{ carousel_options }}'>
      <div class="CarouselWrapper">
      {%- if has_testimonial_block -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'testimonial' -%}
              <div id="Block--{{ block.id }}" class="TestimonialWrapper TestimonialWrapper--{{ block.id }} Carousel__Item {% if section.settings.desktop_items_per_row > 1 %}1/{{ section.settings.desktop_items_per_row | minus: 1 }}--medium-up{% endif %}  1/{{ section.settings.desktop_items_per_row }}--large {% if forloop.first %}is-selected{% endif %}" {{ block.shopify_attributes }} data-slide-index="{% increment slide_index0 %}">
                <div class="Testimonial Testimonial--{{ section.settings.card_align }}{% if section.settings.enable_thumbnail_border %} Testimonial--border{% endif %}{% if section.settings.enable_thumbnail_top %} Testimonial--thumbnailTop{% endif %}">
                  {%- if block.settings.quote != blank -%}
                    <div class="Testimonial__Content">
                      {{ block.settings.quote }}
                    </div>
                  {%- endif -%}

                  {%- if block.settings.thumbnail != blank -%}
                    <div class="Testimonial__ThumbnailWrapper Ratio" style="--tg-aspect-ratio: {{ block.settings.thumbnail.aspect_ratio }};">
                      {{ block.settings.thumbnail | image_url: width: 200 | image_tag:
                        loading: 'lazy',
                        class: 'Testimonial__Thumbnail'
                      }}
                    </div>
                  {%- else -%}
                    <div class="Testimonial__ThumbnailWrapper Ratio" style="--tg-aspect-ratio: 1;">
                      {{ 'image' | placeholder_svg_tag: 'Testimonial__Thumbnail SvgPlaceholder' }}
                    </div>
                  {%- endif -%}

                  <div class="Testimonial__Author">
                    {%- if block.settings.name != blank -%}
                      <div class="Testimonial__AuthorName">{{ block.settings.name | escape }}</div>
                    {%- endif -%}

                    {%- if block.settings.position != blank -%}
                      <div class="Testimonial__AuthorPosition">{{ block.settings.position | escape }}</div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endcase -%}
        {%- endfor -%}
      {%- else -%} 
        {%- for i in (1..3) -%}
          <div class="TestimonialWrapper Carousel__Item {% if section.settings.desktop_items_per_row > 1 %}1/{{ section.settings.desktop_items_per_row | minus: 1 }}--medium-up{% endif %}  1/{{ section.settings.desktop_items_per_row }}--large {% if forloop.first %}is-selected{% endif %}" data-slide-index="{% increment slide_index0 %}">
            <div class="Testimonial Testimonial--{{ section.settings.card_align }}{% if section.settings.enable_thumbnail_border %} Testimonial--border{% endif %}{% if section.settings.enable_thumbnail_top %} Testimonial--thumbnailTop{% endif %}">
              <div class="Testimonial__Content RTE">
                {{ 'sections.testimonials.quote' | t }}
              </div>

              <div class="Testimonial__ThumbnailWrapper Ratio" style="--tg-aspect-ratio: 1;">
                {{ 'image' | placeholder_svg_tag: 'Testimonial__Thumbnail SvgPlaceholder' }}
              </div>

              <div class="Testimonial__Author">
                <div class="Testimonial__AuthorName">{{ 'sections.testimonials.name' | t }}</div>
                <div class="Testimonial__AuthorPosition">{{ 'sections.testimonials.position' | t }}</div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="Carousel__Pagination"></div>
    <div class="Carousel__NavPrev">
      {%- render 'icons', icon: 'nav-right' -%}
    </div>
    <div class="Carousel__NavNext">
      {%- render 'icons', icon: 'nav-right' -%}
    </div>
  </div>
  </div>
</section-testimonials>

{% schema %}
{
  "name": "Testimonials",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_spacing",
      "label": "Section spacing",
      "options": [
        {
          "value": "spacingSmall",
          "label": "Small"
        },
        {
          "value": "spacingMedium",
          "label": "Medium"
        },
        {
          "value": "spacingLarge",
          "label": "Large"
        }
      ],
      "default": "spacingMedium"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "range",
      "min": 1,
      "max": 4,
      "step": 1,
      "id": "desktop_items_per_row",
      "label": "Number of testimonials per row",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate testimonials",
      "default": true
    },
    {
      "type": "range",
      "id": "cycle_speed",
      "min": 3,
      "max": 16,
      "step": 1,
      "unit": "s",
      "label": "Change testimonials every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "select",
      "id": "card_align",
      "label": "Card alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "enable_thumbnail_top",
      "label": "Enable avatar top",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_thumbnail_border",
      "label": "Show card border",
      "info": "Visible when the ‘Card alignment’ setting is set to Left or Right.",
      "default": false
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Name color",
      "default": "#1c1b1b"
    },
    {
      "type": "color",
      "id": "position_color",
      "label": "Job color",
      "default": "#8C8585"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Content color",
      "default": "#1c1b1b"
    },
    {
      "type": "color",
      "id": "quote_background",
      "label": "Content background color",
      "default": "#eaeaea"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Avatar",
          "info": "80 x 80px .jpg recommended."
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Content",
          "default": "<p>Share what your customers are saying about your products, your company...</p>"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "position",
          "label": "Job"
        }
      ]
    },
    {
      "type": "section_header",
      "name": "Section header",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Tell your story"
        },
        {
          "type": "select",
          "id": "header_align",
          "label": "Header alignment",
          "options": [
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "left",
              "label": "Left"
            }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Heading size",
          "options": [
            {
              "value": "HeadlineSmall",
              "label": "Small"
            },
            {
              "value": "HeadlineMedium",
              "label": "Medium"
            },
            {
              "value": "HeadlineLarge",
              "label": "Large"
            }
          ],
          "default": "HeadlineMedium"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#1c1b1b"
        }
      ]
    },
    {
      "type": "background_image",
      "name": "Background image",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "1600 x 800px .jpg recommended."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "settings": {
      },
      "blocks": [
        {
          "type": "section_header"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}