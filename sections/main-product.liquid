{% assign base_title = product.title 
  | remove: ' (Golden)' 
  | remove: ' (Silver)' 
%}

{%- liquid
  assign show_sku = false
  assign show_dynamic_checkout = false
  assign show_inventory_quantity = false
  assign inventory_quantity_threshold = 5
  assign recommendations_related_count = 0
  assign recommendations_complementary_count = 0

  for block in section.blocks
    case block.type
      when 'sku'
        assign show_sku = true
      when 'buy_buttons'
        assign gift_card_recipient_feature_active = false
        if block.settings.show_gift_card_recipient and product.gift_card?
            assign gift_card_recipient_feature_active = true
        endif

        assign show_dynamic_checkout = false
        if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
            assign show_dynamic_checkout = true
        endif
      when 'quantity_selector'
        assign show_inventory_quantity = block.settings.show_inventory_quantity
        assign inventory_quantity_threshold = block.settings.inventory_quantity_threshold
      when 'product_recom_related'
        assign recommendations_related_count = block.settings.grid_items_count
      when 'complementary_products'
        assign recommendations_complementary_count = block.settings.grid_items_count
    endcase
  endfor 

  assign enable_media_grouping = false 
  if section.settings.enable_media_grouping and product.metafields.themegoal.media_grouping_set.value != blank
    assign enable_media_grouping = true
  endif
-%}

{%- capture section_settings -%} 
{
  "productForm": "main-product",
  "productId": {{ product.id | json }},
  "enableHistoryState": true,
  "enableImageZoom": {{ section.settings.enable_image_zoom | json }},
  "imageZoomLayout": {{ section.settings.image_zoom_layout | json }},
  "galleryDesign": {{ section.settings.gallery_design | json }},
  "recommendationsRelatedCount": {{ recommendations_related_count | json }},
  "recommendationsComplementaryCount": {{ recommendations_complementary_count | json }},

  "showSku": {{ show_sku | json }},
  "showPaymentButton": {{ show_dynamic_checkout | json }},

  "showInventoryQuantity": {{ show_inventory_quantity | json }},
  "enableMediaGrouping": {{ enable_media_grouping | json }},
  "inventoryQuantityThreshold": {{ inventory_quantity_threshold }},
  "initCurrentVariantImageId": {{ product.selected_or_first_available_variant.featured_media.id | json }}
}
{%- endcapture -%}

{{ 'component-product-blocks.css' | asset_url | stylesheet_tag }}
<script src="{{ 'component-product-variants.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'section-product.js' | asset_url }}" defer="defer"></script>
{%- if section.settings.enable_image_zoom and section.settings.image_zoom_layout == 'stacked' and section.settings.image_zoom_bg_color != blank and section.settings.image_zoom_bg_color != 'rgba(0,0,0,0)' -%}
  <style>
    .Product--{{ section.id }} + .Modal + .Modal__Backdrop.Show{
      {%- assign zoom_stacked_opacity = section.settings.image_zoom_bg_opacity | divided_by: 100.0 -%}
      background-color: {{ section.settings.image_zoom_bg_color }};
      opacity: {{ zoom_stacked_opacity }};
    }
  </style>
  {%- endif -%}
<style>
  .Product--{{ section.id }} {
    --pdp-navy-color: {{ section.settings.pdp_navy_color }};
    --pdp-radius: {{ section.settings.pdp_corner_radius }}px;
    --pdp-summary-text-color: {{ section.settings.pdp_summary_text_color }};
    --pdp-desktop-gap: {{ section.settings.pdp_desktop_gap }}px;
    --pdp-usp-bg: {{ section.settings.pdp_usp_background }};
    --pdp-usp-text: {{ section.settings.pdp_usp_text_color }};
    --pdp-mobile-media-bg: {{ section.settings.pdp_mobile_media_background }};
    --pdp-mobile-content-bg: {{ section.settings.pdp_mobile_content_background }};
    --pdp-mobile-content-padding: {{ section.settings.pdp_mobile_content_padding }}px;
    --pdp-mobile-thumb-gap: {{ section.settings.pdp_mobile_thumb_gap }}px;
    --pdp-mobile-thumb-height: {{ section.settings.pdp_mobile_thumb_height }}px;
    --pdp-mobile-cta-color: {{ section.settings.pdp_mobile_cta_color }};
  }

  @media screen and (min-width: 1008px) {
    .Product--{{ section.id }} .ProductDesign.Grid {
      column-gap: var(--pdp-desktop-gap);
    }
  }

  .Product--{{ section.id }} .ProductGallery__ImageWrapper,
  .Product--{{ section.id }} .ProductGallery__ImageWrapper img,
  .Product--{{ section.id }} .ProductForm__AddToCart,
  .Product--{{ section.id }} .ProductForm__AddToCart + .Button,
  .Product--{{ section.id }} .VariantSwatch,
  .Product--{{ section.id }} .VariantSelectors__Item,
  .Product--{{ section.id }} .ColorSwatch,
  .Product--{{ section.id }} .Accordion__Item,
  .Product--{{ section.id }} .Accordion__Button {
    border-radius: var(--pdp-radius);
  }

  .Product--{{ section.id }} .ProductSummary {
    color: var(--pdp-summary-text-color);
  }

  .Product--{{ section.id }} .ProductForm__AddToCart {
    background: var(--pdp-navy-color);
    border-color: var(--pdp-navy-color);
    color: #fff;
  }

  .Product--{{ section.id }} .Product__Block--usps .USPBox {
    background: var(--pdp-usp-bg);
    color: var(--pdp-usp-text);
    border-radius: var(--pdp-radius);
  }

  .Product--{{ section.id }} .USPInfo {
    border-radius: 50%;
  }

  {%- if section.settings.enable_mobile_pdp_style -%}
    @media screen and (max-width: 767px) {
      .Product--{{ section.id }} .ProductGallery,
      .Product--{{ section.id }} .ProductGallery__Carousel,
      .Product--{{ section.id }} .ProductGallery__Thumbnails {
        background: var(--pdp-mobile-media-bg);
      }

      .Product--{{ section.id }} .ProductGallery__Thumbnails {
        gap: var(--pdp-mobile-thumb-gap);
        padding: 8px var(--pdp-mobile-content-padding);
      }

      .Product--{{ section.id }} .ProductGallery__Thumbnail {
        max-height: var(--pdp-mobile-thumb-height);
      }

      .Product--{{ section.id }} .ProductGallery__Thumbnail img,
      .Product--{{ section.id }} .ProductGallery__Thumbnail,
      .Product--{{ section.id }} .ProductGallery__ImageWrapper,
      .Product--{{ section.id }} .ProductGallery__ImageWrapper img {
        border-radius: var(--pdp-radius);
      }

      .Product--{{ section.id }} .ProductSummary__Wrapper {
        background: var(--pdp-mobile-content-bg);
        padding: 0 var(--pdp-mobile-content-padding) var(--pdp-mobile-content-padding);
      }

      .Product--{{ section.id }} .ProductSummary {
        margin-top: 0;
        padding-top: 12px;
        position: relative;
        top: auto;
      }

      .Product--{{ section.id }} .ProductForm__AddToCart {
        background: var(--pdp-mobile-cta-color);
        border-color: var(--pdp-mobile-cta-color);
      }

      .Product--{{ section.id }} .ProductForm__AddToCart,
      .Product--{{ section.id }} .ProductForm__AddToCart + .Button {
        border-radius: var(--pdp-radius);
      }
    }
  {%- endif -%}
</style>
<section-product style="display: block;" class="Product Product--{{ section.id }} {% unless product.media.size > 0 %}Product--noMedia{% endunless %} Container Container--specialSpacingFirstSection Container--spacingContainerGutter {% if section.settings.section_width == 'full_width' %}Container--fluid Product--fullWidth{% endif %}" 
  data-section-id="{{ section.id }}" data-section-settings='{{ section_settings }}' data-product-url="{{ product.url }}">
      <div class="ProductDesign Grid">
          {%- if product.media.size > 0 -%}
              <div class="Grid__Item 8/12--large">
                  {%- render 'product-gallery' -%}
              </div>
          {%- endif -%}

          <div class="Grid__Item {% if product.media.size > 0 %}4/12--large{% endif %} ProductSummary__Wrapper">
            <div class="ProductSummary{% if section.settings.section_background_color != blank and section.settings.section_background_color != 'rgba(0,0,0,0)' %} ProductSummary--withBackgroundColor{% endif %}" 
              style="{% if section.settings.section_background_color != blank and section.settings.section_background_color != 'rgba(0,0,0,0)' %}--tg-product-summary-background-color: {{ section.settings.section_background_color }};{% endif %}"
            >
              {%- if section.settings.show_usp_row -%}
                <div class="Product__Block Product__Block--usps">
                  <div class="USPRow">
                    {%- if section.settings.usp_1_text != blank -%}
                      <div class="USPBox">
                        <span>{{ section.settings.usp_1_text }}</span>
                        {%- if section.settings.usp_1_tooltip != blank -%}
                          <button
                            type="button"
                            class="USPInfo"
                            aria-label="More info about '{{ section.settings.usp_1_text | escape }}'"
                            data-tooltip="{{ section.settings.usp_1_tooltip | escape }}"
                          ></button>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    {%- if section.settings.usp_2_text != blank -%}
                      <div class="USPBox">
                        <span>{{ section.settings.usp_2_text }}</span>
                        {%- if section.settings.usp_2_tooltip != blank -%}
                          <button
                            type="button"
                            class="USPInfo"
                            aria-label="More info about '{{ section.settings.usp_2_text | escape }}'"
                            data-tooltip="{{ section.settings.usp_2_tooltip | escape }}"
                          ></button>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    {%- if section.settings.usp_3_text != blank -%}
                      <div class="USPBox">
                        <span>{{ section.settings.usp_3_text }}</span>
                        {%- if section.settings.usp_3_tooltip != blank -%}
                          <button
                            type="button"
                            class="USPInfo"
                            aria-label="More info about '{{ section.settings.usp_3_text | escape }}'"
                            data-tooltip="{{ section.settings.usp_3_tooltip | escape }}"
                          ></button>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
              {%- render 'product-blocks', product_from: 'main-product' -%}
              
            </div>
          </div>
      </div>
</section-product>

{%- if section.settings.enable_image_zoom -%}
  {%- if section.settings.image_zoom_layout == 'carousel' -%}
    {%- render 'product-media-lightbox' -%}
  {%- else -%}
    {%- render 'product-media' -%}
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Product information",
  "class": "shopify-section--main-product",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "default",
          "label": "Grid"
        },
        {
          "value": "full_width",
          "label": "Full width"
        }
      ],
      "default": "full_width"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Summary background color"
    },
    {
      "type": "header",
      "content": "Desktop PDP style"
    },
    {
      "type": "color",
      "id": "pdp_navy_color",
      "label": "Navy color",
      "default": "#121B50"
    },
    {
      "type": "color",
      "id": "pdp_summary_text_color",
      "label": "Summary text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "pdp_corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "pdp_desktop_gap",
      "label": "Desktop column gap",
      "min": 0,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile PDP style"
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_pdp_style",
      "label": "Enable mobile PDP style",
      "default": true
    },
    {
      "type": "color",
      "id": "pdp_mobile_media_background",
      "label": "Mobile media background",
      "default": "#ECECEC"
    },
    {
      "type": "color",
      "id": "pdp_mobile_content_background",
      "label": "Mobile content background",
      "default": "#F3F3F3"
    },
    {
      "type": "color",
      "id": "pdp_mobile_cta_color",
      "label": "Mobile CTA color",
      "default": "#121B50"
    },
    {
      "type": "range",
      "id": "pdp_mobile_content_padding",
