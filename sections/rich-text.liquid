{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}
{%- assign has_button = false -%}
{%- assign has_two_buttons = false -%}

<section class="Container Container--specialSpacingFirstSection RichText RichText--{{ section.settings.content_align }}
{% if section.settings.section_width == 'full_width' %} Container--fluid {% endif %}
{% if section.settings.background != blank and section.settings.background != 'rgba(0,0,0,0)' and section.settings.section_width == 'full_width' %}
 Container--{{ section.settings.section_spacing }}Padding Container--noGutter Container--specialSpacingLastSection 
{% elsif section.settings.background != blank and section.settings.background != 'rgba(0,0,0,0)' %}
 Container--{{ section.settings.section_spacing }}Padding Container--{{ section.settings.section_spacing }} 
{% else %}
 Container--{{ section.settings.section_spacing }}
{% endif %}" 
 {% if section.settings.background %}style="background: {{ section.settings.background }}"{% endif %}
 data-section-id="{{ section.id }}">
  <div class="" {% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}
    style="--tg-section-header-text-color:{{ section.settings.text_color }};
    --tg-compontent-button-underline-text-color:{{ section.settings.text_color }};
    --tg-compontent-button-underline-text-color-active:{{ section.settings.text_color }};
    color: {{ section.settings.text_color }}"{% endif %}>
    <header class="SectionHeader">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2 class="SectionHeader__Heading CustomSize {{ block.settings.heading_font_size }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
          {%- when 'subheading' -%}
            <div class="SectionHeader__Subheading TextMuted" {{ block.shopify_attributes }}>{{ block.settings.text }} </div>
          {%- when 'description' -%}
            <div class="SectionHeader__Description RTE" {{ block.shopify_attributes }}>
             {{ block.settings.text }}
            </div>
          {%- when 'button' -%}
            {%- if has_button -%} 
              {%- assign has_two_buttons = true -%}
            {%- endif -%}
            {%- assign has_button = true -%}
            
        {%- endcase -%}
      {%- endfor -%}

      {%- if has_button -%}
        <div class="SectionHeader__ButtonWrapper">
          <div class="ButtonGroup {% if has_two_buttons %}ButtonGroup--smallSize{% endif %}">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'button' -%}
                  <a href="{{ block.settings.link }}" class="Button Button--{{ block.settings.style }} {{ block.shopify_attributes }}">{{ block.settings.label | escape }}</a>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </header>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "default",
          "label": "Grid"
        },
        {
          "value": "full_width",
          "label": "Full width"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "Section spacing",
      "options": [
        {
          "value": "spacingSmall",
          "label": "Small"
        },
        {
          "value": "spacingMedium",
          "label": "Medium"
        },
        {
          "value": "spacingLarge",
          "label": "Large"
        }
      ],
      "default": "spacingMedium"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Talk about your brand"
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Heading size",
          "options": [
            {
              "value": "HeadlineSmall",
              "label": "Small"
            },
            {
              "value": "HeadlineMedium",
              "label": "Medium"
            },
            {
              "value": "HeadlineLarge",
              "label": "Large"
            }
          ],
          "default": "HeadlineMedium"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subeading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            {
              "value": "primary",
              "label": "Primary"
            },
            {
              "value": "secondary",
              "label": "Secondary"
            },
            {
              "value": "outline",
              "label": "Outline"
            },
            {
              "value": "underline",
              "label": "Underline"
            }
          ],
          "default": "secondary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rich text",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "description"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}