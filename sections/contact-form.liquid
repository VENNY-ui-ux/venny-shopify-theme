{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{% liquid
  assign section_header_align = 'center'
  if section.settings.header_align == 'left'
    assign section_header_align = 'start'
  elsif section.settings.header_align == 'right'
    assign section_header_align = 'end'
  endif
%}

<section class="Container Container--specialSpacingFirstSection{% if section.settings.section_width == 'full_width' %} Container--fluid{% endif %} Container--{{ section.settings.section_spacing }} ContactForm">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="SectionHeader SectionHeader--{{ section.settings.header_align }} ContactForm__Header">
          
        {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
          <div class="SectionHeader__Text">
            {%- if section.settings.heading != blank -%}
                <h2 class="SectionHeader__Heading CustomSize {{ section.settings.heading_font_size }}">{{ section.settings.heading }}</h2>
            {%- endif -%}

            {%- if section.settings.subheading != blank -%}
                <div class="SectionHeader__Subheading TextMuted">{{ section.settings.subheading }} </div>
            {%- endif -%}
          </div>
        {%- endif -%}
          
      </header>
    {%- endif -%}

    <div class="SectionBody ContactForm__Body">
      {%- form 'contact' -%}

        {%- unless section.settings.description == blank -%}
          <div class="ContactForm__Description RTE" style="text-align: {{ section_header_align }}">
              {{ section.settings.description }}
          </div>
        {%- endunless -%}

        {%- if form.posted_successfully? -%}
          <div class="Alert Alert--success RTE" style="text-align: {{ section_header_align }}">
            {{ 'contact.form.successfully_sent' | t }}
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="Form__Alert Alert Alert--danger" style="text-align: {{ section_header_align }}">
              <ul class="List List--unstyle">
                {%- for field in form.errors -%}
                  {%- if field == 'form' -%}
                    <li>{{ form.errors.messages[field] }}</li>
                  {%- else -%}
                    <li><strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}</li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endif -%}

      <div class="Grid">
        <div class="Grid__Item 1/2--medium-up">
            <div class="Form__Item Form__Item--floatingLabel">
                <input id="ContactFormName--{{ section.id }}" type="text" name="contact[name]" class="Form__Input" aria-label="{{ 'contact.form.name' | t }}" placeholder="{{ 'contact.form.name' | t }}" required {% if customer %}value="{{ customer.name }}"{% endif %}>
                <label class="Form__Label" for="ContactFormName--{{ section.id }}">{{ 'contact.form.name' | t }}</label>
            </div>
        </div>

        <div class="Grid__Item 1/2--medium-up">
            <div class="Form__Item Form__Item--floatingLabel">
                <input id="ContactFormEmail--{{ section.id }}" type="email" name="contact[email]" pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$" title="{{ 'general.meta.email_format' | t }}" class="Form__Input" aria-label="{{ 'contact.form.email' | t }}" placeholder="{{ 'contact.form.email' | t }}" required {% if customer %}value="{{ customer.email }}"{% endif %}>
                <label class="Form__Label" for="ContactFormEmail--{{ section.id }}">{{ 'contact.form.email' | t }}</label>
            </div>
        </div>


        {%- for block in section.blocks -%}
          {%- if block.type == 'dropdown' or block.type == 'text' -%}
            <div class="Grid__Item {% unless block.settings.full_with %}1/2--medium-up{% endunless %}" {{ block.shopify_attributes }}>
              <div class="Form__Item Form__Item--floatingLabel">
                {%- assign field_title = block.settings.heading -%} 

                {%- if field_title == blank -%}
                  {%- capture field_title -%}Custom field {% increment custom_field %}{%- endcapture -%}
                {%- endif -%}

                {%- if block.type == 'text' -%}
                  
                  {%- if block.settings.use_long_text -%}
                    <textarea id="ContactFormText--{{ section.id }}-{{ block.id }}" class="Form__Input" name="contact[{{ field_title | escape }}]" cols="30" rows="10" aria-label="{{ block.settings.heading | escape }}" placeholder="{{ block.settings.heading | escape }}" required style="height: 200px" {% if block.settings.is_required %}required{% endif %}></textarea>
                    <label class="Form__Label" for="ContactFormText--{{ section.id }}-{{ block.id }}">{{ block.settings.heading | escape }}</label>
                  {%- else -%}
                    <input type="text" id="ContactFormText--{{ section.id }}-{{ block.id }}" name="contact[{{ field_title | escape }}]" class="Form__Input" aria-label="{{ block.settings.heading | escape }}" placeholder="{{ block.settings.heading | escape }}" {% if block.settings.is_required %}required{% endif %}>
                    <label class="Form__Label" for="ContactFormText--{{ section.id }}-{{ block.id }}">{{ block.settings.heading | escape }}</label>
                  {%- endif -%}
                  
                {%- elsif block.type == 'dropdown' -%}
                  {%- assign values = block.settings.values | split: ',' -%}

                  {%- if values == empty -%}
                    {%- continue -%}
                  {%- endif -%}
                    <select id="ContactFormDropdown--{{ section.id }}-{{ block.id }}" class="Form__Select" name="contact[{{ field_title | escape }}]" title="{{ block.settings.heading | escape }}" {% if block.settings.is_required %}required{% endif %}>
                        <option value="" selected>{{ block.settings.heading | escape }}</option>
                        {%- for value in values -%}
                          {%- assign trim_value = value | strip -%}

                          <option value="{{ trim_value | escape }}">{{ trim_value | escape }}</option>
                        {%- endfor -%}
                    </select>
                    <label class="Form__Label" for="ContactFormDropdown--{{ section.id }}-{{ block.id }}">{{ block.settings.heading | escape }}</label>
                {%- endif -%}
            
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        <div class="Grid__Item">
            <div class="Form__Item Form__Item--floatingLabel">
                <textarea id="ContactFormBody--{{ section.id }}" class="Form__Input" name="contact[body]" aria-label="{{ 'contact.form.message' | t }}" placeholder="{{ 'contact.form.message' | t }}" required style="height: 200px"></textarea>
                <label class="Form__Label" for="ContactFormBody--{{ section.id }}">{{ 'contact.form.message' | t }}</label>
            </div>
        </div>


        <div class="Grid__Item" style="text-align: {{ section_header_align }};">
            <button class="Button Button--primary" type="submit">{{ 'contact.form.submit' | t }}</button>
        </div>
      </div>
    {% endform %} 
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "default",
          "label": "Grid"
        },
        {
          "value": "full_width",
          "label": "Full width"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "Section spacing",
      "options": [
        {
          "value": "spacingSmall",
          "label": "Small"
        },
        {
          "value": "spacingMedium",
          "label": "Medium"
        },
        {
          "value": "spacingLarge",
          "label": "Large"
        }
      ],
      "default": "spacingMedium"
    },
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact form"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading size",
      "options": [
        {
          "value": "HeadlineSmall",
          "label": "Small"
        },
        {
          "value": "HeadlineMedium",
          "label": "Medium"
        },
        {
          "value": "HeadlineLarge",
          "label": "Large"
        }
      ],
      "default": "HeadlineMedium"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "id": "description",
      "type": "richtext",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text field",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Name",
          "default": "Custom field"
        },
        {
          "type": "checkbox",
          "id": "use_long_text",
          "label": "Use long text",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "is_required",
          "label": "Field is required",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "full_with",
          "label": "Use full width",
          "default": true
        }
      ]
    },
    {
      "type": "dropdown",
      "name": "Dropdown",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Name",
          "default": "Custom field"
        },
        {
          "type": "text",
          "id": "values",
          "label": "Values",
          "info": "Separate each value by a comma.",
          "default": "value 1, value 2, value 3"
        },
        {
          "type": "checkbox",
          "id": "is_required",
          "label": "Field is required",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "full_with",
          "label": "Use full width",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}
