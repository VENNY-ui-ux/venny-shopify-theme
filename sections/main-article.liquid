{%- liquid
  assign share_url = shop.url | append: article.url 
  assign twitter_text = article.title 
  assign pinterest_description = article.description | strip_html | truncatewords: 15 | url_param_escape 
  assign pinterest_image = article.image | image_url: width: 750 | prepend: 'https:' 

  assign add_gap =  true 
  if section.settings.page_header_width == 'full_width_no_gap'
      assign add_gap =  false 
  endif 

  assign article_image = article.image
  assign page_header_height = section.settings.page_header_height


  assign article_subtitle = ''
  assign article_title = article.title
  if section.settings.show_category
    assign article_category = article.tags.first | default: blog.title
  endif 
-%}

{%- if section.settings.show_date -%}
  {%- capture article_published_at -%}
    <span class="Aiticle__PublishedAt">{{ article.published_at | date: format: 'month_day_year' }}</span>
  {%- endcapture -%}
  {%- assign article_subtitle = article_subtitle | append: article_published_at -%}
{%- endif -%}

{%- if section.settings.show_author -%}
  {%- capture article_author -%}
    <span class="Article__Author">{{ article.author }}</span>
  {%- endcapture -%}
  {%- assign article_subtitle = article_subtitle | append: article_author -%}
{%- endif -%}


{% render 'page-header', 
  background_image: article_image, 
  page_header_height: page_header_height,
  background_color: section.settings.page_header_bg_color,
  badge: article_category,
  page_header_title: article_title,
  page_header_description: article_subtitle,
  add_gap: add_gap
%}


<article class="Article Container" data-section-id="{{ section.id }}">

    <div class="Container Container--narrow">
      <div class="Article__Content">
        <div class="Article__Body RTE">
          {{ article.content }}
        </div>

        {%- if section.settings.show_share_buttons -%}
          <footer class="Article__Footer">
            <div class="Article__ShareButtons ShareButtons">
              <span class="ShareTitle TextMuted">{{ 'blog.article.share' | t }}</span>
              <div class="ShareList">
                <a class="TextMuted Button Button--icon" role="button" href="https://www.facebook.com/sharer.php?u={{ share_url }}" target="_blank" rel="noopener">{% render 'icons', icon: 'facebook' %}</a>
                <a class="TextMuted Button Button--icon" role="button" href="https://twitter.com/intent/tweet?{% if twitter_text != blank %}text={{ twitter_text | url_param_escape }}&{% endif %}url={{ share_url }}" target="_blank" rel="noopener">{% render 'icons', icon: 'twitter' %}</a>
                <a class="TextMuted Button Button--icon" role="button" href="https://pinterest.com/pin/create/button/?url={{ share_url }}{% if pinterest_image != blank %}&media={{ pinterest_image }}{% endif %}&description={{ pinterest_description }}" target="_blank" rel="noopener">{% render 'icons', icon: 'pinterest' %}</a>
              </div>
            </div>
          </footer>
        {%- endif -%}
      </div> 

      {%- if blog.comments_enabled? -%}
        {%- if article.comments_count > 0 -%}
          <div class="Article__Comments">
            <span class="anchor" id="comments"></span>

            <h2 class="Article__CommentsCount">{{ 'blog.article.comments_count' | t: count: article.comments_count }}</h2>

            <div class="Article__CommentList">
              {%- paginate article.comments by 25 -%}
                {%- for comment in article.comments -%}
                  <div class="ArticleComment">
                    <div class="ArticleComment__Body RTE">
                      {{ comment.content }}
                    </div>

                    <div class="ArticleComment__Meta">
                      <span class="ArticleComment__Author">{{ comment.author }}</span>
                      <span class="ArticleComment__Date TextMuted">{{ comment.created_at | date: format: 'month_day_year' }}</span>
                    </div>
                  </div>
                {%- endfor -%}

                {% render 'pagination', paginate: paginate, hash: '#Comments' %}
              {%- endpaginate -%}
            </div>
          </div>
        {%- endif -%}

        <div class="Article__CommentFormWrapper">
          {% if article.comments_count == 0 %}
            <span class="anchor" id="Comments"></span>
          {%- endif -%}

          <h2 class="Article__CommentFormTitle">{{ 'blog.comments.form_title' | t }}</h2>

          {%- form 'new_comment', article, class: 'Form Article__CommentForm' -%}
            {%- if form.posted_successfully? -%}
              <p class="Alert Alert--success">
                {%- if blog.moderated? -%}
                  {{- 'blog.comments.success_moderated' | t -}}
                {%- else -%}
                  {{- 'blog.comments.success' | t -}}
                {%- endif -%}
              </p>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="Form__Alert Alert Alert--danger">
                <ul class="List List--unstyle">
                  {%- for field in form.errors -%}
                    {%- if field == 'form' -%}
                      <li>{{ form.errors.messages[field] }}</li>
                    {%- else -%}
                      <li><strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}

            <div class="Form__Item Form__Item--floatingLabel">
              <input id="ArticleCommentFormAuthor--{{ section.id }}" type="text" class="Form__Input" name="comment[author]" placeholder="{{ 'blog.comments.name_placeholder' | t }}" aria-label="{{ 'blog.comments.name_placeholder' | t }}" value="{{ form.author | escape | default: customer.name }}" required="required">
              <label class="Form__Label" for="ArticleCommentFormAuthor--{{ section.id }}">{{ 'blog.comments.name_placeholder' | t }}</label>
            </div>

            <div class="Form__Item Form__Item--floatingLabel">
              <input id="ArticleCommentFormEmail--{{ section.id }}" type="email" class="Form__Input" pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$" title="{{ 'general.meta.email_format' | t }}" name="comment[email]" placeholder="{{ 'blog.comments.email_placeholder' | t }}" aria-label="{{ 'blog.comments.email_placeholder' | t }}" value="{{ form.email | escape | default: customer.email }}" required="required">
              <label class="Form__Label" for="ArticleCommentFormEmail--{{ section.id }}">{{ 'blog.comments.email_placeholder' | t }}</label>
            </div>

            <div class="Form__Item Form__Item--floatingLabel">
              <textarea id="ArticleCommentFormBody--{{ section.id }}" class="Form__Input" name="comment[body]" placeholder="{{ 'blog.comments.comment_placeholder' | t }}"  aria-label="{{ 'blog.comments.comment_placeholder' | t }}" required="required" style="height: 160px">
                {{- form.body -}}
              </textarea>
              <label class="Form__Label" for="ArticleCommentFormBody--{{ section.id }}">{{ 'blog.comments.comment_placeholder' | t }}</label>
            </div>
           
            {%- if blog.moderated? -%}
              <p class="TextMuted">{{ 'blog.comments.approval_notice' | t }}</p>
            {%- endif -%}

            <button type="submit" class="Form__Submit Button Button--primary">{{ 'blog.comments.submit' | t }}</button>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>


</article>

{% schema %}
{
  "name": "Blog post page",
  "settings": [
    {
      "type": "header",
      "content": "Page header"
    },
    {
      "type": "select",
      "id": "page_header_width",
      "label": "Width",
      "options": [
        {
          "value": "full_width",
          "label": "Full width"
        },
        {
          "value": "full_width_no_gap",
          "label": "Full width no gap"
        }
      ],
      "default": "full_width"
    },
    {
      "type": "select",
      "id": "page_header_height",
      "options": [
        {
          "value": "fitContent",
          "label": "Fit Content"
        },
        {
          "value": "Small",
          "label": "Small"
        },
        {
          "value": "Medium",
          "label": "Medium"
        },
        {
          "value": "Large",
          "label": "Large"
        }
      ],
      "default": "Medium",
      "label": "Height"
    },
    {
      "type": "color",
      "id": "page_header_bg_color",
      "label": "Background color",
      "info": "Visible when the post's featured image is blank."
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "Show date"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": true,
      "label": "Show author"
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show article category",
      "info": "The first article's tag is used as the main category.",
      "default": true
    },
    {
      "type": "header",
      "content": "Share buttons"
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show share buttons",
      "default": true
    }
  ]
}
{% endschema %}