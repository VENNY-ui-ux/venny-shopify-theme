{% comment %}
  Cart drawer section for VENNY (Chord theme / Chord-like)
  - Viser drawer med progress bar, items, totals og knapper
  - Bruger temaets Drawer-system via data-tg-dismiss / data-tg-toggle
{% endcomment %}

{% assign free_shipping_threshold = section.settings.free_shipping_threshold | default: 499 %}
{% assign cart_total = cart.total_price | divided_by: 100 %}

<div
  id="CartDrawer"
  class="Drawer Drawer--end CartDrawer"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  data-section-id="{{ section.id }}"
>

  {%- comment -%}
    Overlay inde i drawer – klik uden for selve boksen for at lukke
  {%- endcomment -%}
  <div class="CartDrawer__Overlay" data-tg-dismiss="Drawer"></div>

  {%- comment -%}
    Selve indholdet i drawer’en
  {%- endcomment -%}
  <div class="CartDrawer__Inner" data-drawer-inner>
    <!-- Header -->
    <header class="CartDrawer__Header">
      <h2 class="CartDrawer__Title">Your cart</h2>
      <button
        type="button"
        class="ButtonClose CartDrawer__Close"
        data-tg-dismiss="Drawer"
        aria-label="Close cart"
      >
        ✕
      </button>
    </header>

    <!-- Progress bar / free shipping -->
    <section class="CartDrawer__ProgressSection">
      {% if cart.item_count > 0 %}
        {% if cart_total >= free_shipping_threshold %}
          <p class="CartDrawer__ProgressText CartDrawer__ProgressText--success">
            You have free shipping 🎉
          </p>
          <div class="CartDrawer__ProgressBar">
            <div class="CartDrawer__ProgressBarFill CartDrawer__ProgressBarFill--full"></div>
          </div>
        {% else %}
          {% assign remaining = free_shipping_threshold | minus: cart_total %}
          <p class="CartDrawer__ProgressText">
            You are {{ remaining | money_without_trailing_zeros }} away from free shipping
          </p>
          {% assign pct = cart_total | times: 100 | divided_by: free_shipping_threshold %}
          <div class="CartDrawer__ProgressBar">
            <div class="CartDrawer__ProgressBarFill" style="width: {{ pct }}%;"></div>
          </div>
        {% endif %}
      {% else %}
        <p class="CartDrawer__ProgressText">
          Your cart is empty.
        </p>
      {% endif %}
    </section>

    <!-- Items -->
    <section class="CartDrawer__Items" data-cart-items>
      {% if cart.item_count > 0 %}
        {% render 'cart-items-drawer' %}
      {% else %}
        <p class="CartDrawer__Empty">
          There are no items in your cart yet.
        </p>
      {% endif %}
    </section>

    {% if cart.item_count > 0 %}
      <!-- Small info / note row -->
      <section class="CartDrawer__InfoRow">
        <div class="CartDrawer__InfoPill">
          <span>✅ 30 days return</span>
        </div>
        <div class="CartDrawer__InfoPill">
          <span>🔒 Secure checkout</span>
        </div>
      </section>

      <!-- Totals -->
      <section class="CartDrawer__Totals">
        {% if cart.total_discount > 0 %}
          <div class="CartDrawer__Row CartDrawer__Row--savings">
            <span>Savings</span>
            <span>-{{ cart.total_discount | money }}</span>
          </div>
        {% endif %}

        <div class="CartDrawer__Row CartDrawer__Row--subtotal">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>

        <p class="CartDrawer__TaxNote">
          Taxes and shipping calculated at checkout.
        </p>
      </section>

      <!-- Button -->
      <section class="CartDrawer__Buttons">
        <a
          href="{{ routes.checkout_url }}"
          class="Button Button--primary CartDrawer__Button CartDrawer__Button--primary"
        >
          Checkout
        </a>
      </section>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold (in shop currency)",
      "default": 499
    }
  ]
}
{% endschema %}
