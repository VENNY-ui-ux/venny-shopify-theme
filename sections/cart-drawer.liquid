{% liquid
  assign free_shipping_threshold = section.settings.free_shipping_threshold | default: 499
  assign campaign_threshold = section.settings.campaign_item_threshold | default: 3
  assign cart_total = cart.total_price | divided_by: 100.0
  assign progress_pct = 0
  assign shipping_text = section.settings.shipping_paid_label | default: 'Calculated at checkout'
  assign first_product_id = blank
  if cart.items.first and cart.items.first.product
    assign first_product_id = cart.items.first.product.id
  endif

  if cart.item_count > 0 and campaign_threshold > 0
    assign progress_pct = cart.item_count | times: 100.0 | divided_by: campaign_threshold
    if progress_pct > 100
      assign progress_pct = 100
    endif
  endif
%}

{% capture campaign_message %}
  {% if cart.item_count == 0 %}
    {{ section.settings.campaign_message_empty | default: 'ADD [remaining] ITEMS & GET ONE FREE' | replace: '[remaining]', campaign_threshold }}
  {% elsif cart.item_count >= campaign_threshold %}
    {{ section.settings.campaign_message_success | default: 'YOU UNLOCKED YOUR REWARD' }}
  {% else %}
    {% assign remaining_campaign = campaign_threshold | minus: cart.item_count %}
    {{ section.settings.campaign_message_progress | default: 'ADD [remaining] ITEMS & GET ONE FREE' | replace: '[remaining]', remaining_campaign }}
  {% endif %}
{% endcapture %}

{% if free_shipping_threshold > 0 and cart_total >= free_shipping_threshold %}
  {% assign shipping_text = section.settings.shipping_free_label | default: 'Free' %}
{% endif %}

<div
  id="CartDrawer"
  class="Drawer Drawer--end CartDrawer CartDrawer--v2"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="CartDrawerHeading"
  tabindex="-1"
  data-section-id="{{ section.id }}"
  data-campaign-threshold="{{ campaign_threshold }}"
  data-first-product-id="{{ first_product_id }}"
>
  <div class="CartDrawer__Overlay" data-tg-dismiss="Drawer"></div>

  <div class="CartDrawer__Inner" data-drawer-inner>
    <header class="CartDrawer__Header">
      <h2 id="CartDrawerHeading" class="CartDrawer__Title">{{ section.settings.drawer_title | default: 'SHOPPING CART' }}</h2>
      <button type="button" class="ButtonClose CartDrawer__Close" data-tg-dismiss="Drawer" aria-label="{{ 'general.drawer.close' | t }}">
        {% render 'icons', icon: 'close' %}
      </button>
    </header>

    <section class="CartDrawer__Campaign" aria-live="polite">
      <p class="CartDrawer__CampaignText">{{ campaign_message | strip }}</p>
      <div class="CartDrawer__ProgressBar" role="progressbar" aria-valuemin="0" aria-valuemax="{{ campaign_threshold }}" aria-valuenow="{{ cart.item_count | at_most: campaign_threshold }}">
        <div class="CartDrawer__ProgressBarFill" style="width: {{ progress_pct }}%;"></div>
      </div>
    </section>

    {% if cart.item_count > 0 %}
      <div class="CartDrawer__ItemsScroll">
        <section class="CartDrawer__Items" data-cart-items aria-label="{{ section.settings.drawer_title | default: 'Shopping cart items' }}">
          {% render 'cart-items-drawer' %}
        </section>
      </div>

      <div class="CartDrawer__StickyStack">
        {% render 'cart-drawer-recommendations', section: section %}

        <section class="CartDrawer__Summary">
          <div class="CartDrawer__Row">
            <span>{{ section.settings.subtotal_label | default: 'Subtotal' }}</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <div class="CartDrawer__Row">
            <span>{{ section.settings.shipping_label | default: 'Shipping' }}</span>
            <span>{{ shipping_text }}</span>
          </div>
          {% if cart.total_discount > 0 %}
            <div class="CartDrawer__Row CartDrawer__Row--discount">
              <span>{{ section.settings.savings_label | default: 'Savings' }}</span>
              <span>-{{ cart.total_discount | money }}</span>
            </div>
          {% endif %}
          <div class="CartDrawer__Delivery">{{ section.settings.estimated_delivery_text | default: 'Estimated delivery: 2-4 business days' }}</div>
          <p class="CartDrawer__TaxNote">{{ section.settings.tax_note | default: 'We cover all import duties & taxes for EU orders' }}</p>
        </section>
        <footer class="CartDrawer__Footer">
          <a href="{{ routes.checkout_url }}" class="Button Button--primary CartDrawer__CheckoutButton" aria-label="{{ section.settings.checkout_button_label | default: 'CHECKOUT SECURELY' }}">
            {{ section.settings.checkout_button_label | default: 'CHECKOUT SECURELY' }}
          </a>
        </footer>
      </div>
    {% else %}
      <section class="CartDrawer__EmptyState">
        <p class="CartDrawer__EmptyTitle">{{ section.settings.empty_title | default: 'Your cart is empty' }}</p>
        <p class="CartDrawer__EmptyText">{{ section.settings.empty_text | default: 'Looks like you have not added anything yet.' }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="Button Button--primary CartDrawer__ContinueButton">
          {{ section.settings.empty_button_label | default: 'Continue shopping' }}
        </a>
      </section>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold (in shop currency)",
      "default": 499
    },
    {
      "type": "text",
      "id": "drawer_title",
      "label": "Drawer title",
      "default": "SHOPPING CART"
    },
    {
      "type": "number",
      "id": "campaign_item_threshold",
      "label": "Campaign threshold (item count)",
      "default": 3
    },
    {
      "type": "text",
      "id": "campaign_message_empty",
      "label": "Campaign message (empty cart)",
      "default": "ADD [remaining] ITEMS & GET ONE FREE"
    },
    {
      "type": "text",
      "id": "campaign_message_progress",
      "label": "Campaign message (in progress)",
      "default": "ADD [remaining] ITEMS & GET ONE FREE"
    },
    {
      "type": "text",
      "id": "campaign_message_success",
      "label": "Campaign message (success)",
      "default": "YOU UNLOCKED YOUR REWARD"
    },
    {
      "type": "text",
      "id": "subtotal_label",
      "label": "Subtotal label",
      "default": "Subtotal"
    },
    {
      "type": "text",
      "id": "shipping_label",
      "label": "Shipping label",
      "default": "Shipping"
    },
    {
      "type": "text",
      "id": "shipping_paid_label",
      "label": "Shipping paid label",
      "default": "Calculated at checkout"
    },
    {
      "type": "text",
      "id": "shipping_free_label",
      "label": "Shipping free label",
      "default": "Free"
    },
    {
      "type": "text",
      "id": "savings_label",
      "label": "Savings label",
      "default": "Savings"
    },
    {
      "type": "text",
      "id": "estimated_delivery_text",
      "label": "Estimated delivery text",
      "default": "Estimated delivery: 2-4 business days"
    },
    {
      "type": "text",
      "id": "tax_note",
      "label": "Tax note",
      "default": "We cover all import duties & taxes for EU orders"
    },
    {
      "type": "text",
      "id": "checkout_button_label",
      "label": "Checkout button label",
      "default": "CHECKOUT SECURELY"
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Empty cart title",
      "default": "Your cart is empty"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty cart text",
      "default": "Looks like you have not added anything yet."
    },
    {
      "type": "text",
      "id": "empty_button_label",
      "label": "Empty cart button label",
      "default": "Continue shopping"
    },
    {
      "type": "collection",
      "id": "recommendations_collection",
      "label": "Recommendations collection (fallback)"
    },
    {
      "type": "range",
      "id": "recommendations_limit",
      "label": "Recommendations limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ]
}
{% endschema %}
