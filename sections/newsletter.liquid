{{ 'component-text-on-image.css' | asset_url | stylesheet_tag }}
{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign has_text = false 

  for block in section.blocks 
    case block.type 
      when 'heading' 
        assign has_text = true 
      when 'subheading' 
        assign has_text = true 
      when 'description' 
        assign has_text = true 

      when 'background_image' 
        assign has_background_image = true 
        assign background_image = block.settings.image 
        assign background_image_block_attributes = block.shopify_attributes 
        assign background_image_overlay_opacity = block.settings.overlay_opacity
    endcase 
  endfor 

  assign animation_image_loading_tag = 'div'
  assign animation_image_loading_class = 'TextOnImage__Image Image--fadeIn'
  if settings.animation_image_loading == 'circle_icon'
    assign animation_image_loading_tag = 'feature-img'
    assign animation_image_loading_class = 'TextOnImage__Image Image--withLoader Image--fadeIn'
  endif

-%}

<style>
  {%- if section.settings.background_color != blank -%}
    {%- unless background_image -%}
    #section-{{ section.id }}{
      background-color:{{ section.settings.background_color }};
    }
    {%- endunless -%}
  {%- endif -%}

  {% if background_image_overlay_opacity > 0 %}
    #section-{{ section.id }} .TextOnImage__ImageWrapper.ImageOverlay::after{
      {%- assign overlay_opacity = background_image_overlay_opacity | divided_by: 100.0 -%}
      background-color: rgba(0,0,0,{{ overlay_opacity }});
    }
  {% endif %}

  {%- for block in section.blocks -%}
    {%- case block.type -%}  
      {%- when 'heading' -%}
        #section-{{ section.id }} .SectionHeader__Heading{
          color: {{ block.settings.color }};
        } 
      {%- when 'subheading' -%}
        #section-{{ section.id }} .SectionHeader__Subheading{
          color: {{ block.settings.color }};
        } 
      {%- when 'description' -%}
        #section-{{ section.id }} .SectionHeader__Description{
          color: {{ block.settings.color }};
        }
        #section-{{ section.id }} .SectionHeader__Description a{
          color: {{ block.settings.color }};
          text-decoration-color: {{ block.settings.color }};
        }
      {%- when 'email_form' -%}
        #section-{{ section.id }} .Form--newsletter .Form__Input,
        #section-{{ section.id }} .Form--newsletter .Form__Input::placeholder{
          color: {{ block.settings.button_background_color }};
        }
        #section-{{ section.id }} .Form--newsletter .Form__Submit {
          color: {{ block.settings.button_label_color }};
          border-color: {{ block.settings.button_background_color }};
          background-color:{{ block.settings.button_background_color }};
        }
        #section-{{ section.id }} .Form--newsletter .Form__Input {
          border-color: {{ block.settings.button_background_color }};
          background: initial;
        }

    {%- endcase -%}
  {%- endfor -%}

</style>

<section id="section-{{ section.id }}" class="Container Container--specialSpacingFirstSection Container--relative Container--fluid Container--noGutter Container--specialSpacingLastSection Newsletter">  

  <div class="TextOnImage TextOnImage--{{ section.settings.content_position }} TextOnImage--fixedHeight{{ section.settings.section_height }}"
  style="--tg-component-text-on-image-image-ratio-mobile: 1; --tg-component-text-on-image-image-ratio: 25;">
    {%- if has_background_image -%}
      {%- if background_image -%}
        <{{- animation_image_loading_tag }} class="TextOnImage__ImageWrapper Ratio {% if background_image_overlay_opacity > 0 %}ImageOverlay{% endif %}">
          {{ background_image | image_url: width: 3840 | image_tag:
            loading: 'lazy',
            sizes: '100vw',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
            class: animation_image_loading_class
          }}

          {%- if settings.animation_image_loading != 'none' -%}
            <span class="Image--loader"></span>
          {%- endif -%}
        </{{- animation_image_loading_tag }}>
      {%- else -%}
        <div class="TextOnImage__ImageWrapper Ratio" {{ background_image_block_attributes }}>
          {{ 'lifestyle-1' | placeholder_svg_tag: 'TextOnImage__Image SvgPlaceholder' }}
        </div>
      {%- endif -%}
    {%- endif -%}

    <!-- content -->
    <div class="TextOnImage__Content">
      <div class="TextOnImage__ContentInner">
        <div>
          {%- if has_text -%}
            <header class="SectionHeader">
              {%- for block in section.blocks -%}
                {%- case block.type -%}    
                  {%- when 'heading' -%}
                    <h2 class="SectionHeader__Heading CustomSize {{ block.settings.heading_font_size }}" {{ block.shopify_attributes }}>
                      {{ block.settings.text }}
                    </h2>

                  {%- when 'subheading' -%}
                    <h3 class="SectionHeader__Subheading" {{ block.shopify_attributes }}>{{ block.settings.text }}</h3>
                    
                  {%- when 'description' -%}
                    <div class="SectionHeader__Description RTE" {{ block.shopify_attributes }}>
                      {{ block.settings.text }}
                    </div>
                {%- endcase -%}
              {%- endfor -%}
            </header>
          {%- endif -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}    
              {%- when 'email_form' -%}
                <div {{ block.shopify_attributes }}>
                  {%- assign newsletter_section_id = 'NewsletterSection-' | append: section.id -%}
                  {%- form 'customer', id: newsletter_section_id, class: 'Form Form--newsletter' -%}
                      {%- if form.posted_successfully? -%}
                        <p class="Alert Alert--success">{{ 'sections.newsletter.success' | t }}</p>
                      {%- else -%}
                        {%- if form.errors -%}
                          <p class="Alert Alert-danger">{{ form.errors.messages['email'] }}</p>
                        {%- endif -%}

                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="Form__ItemGroup">
                          <div class="Form__Item Newsletter__EmailWrapper">
                            <input id="NewletterFormEmail--{{ section.id }}-{{ block.id }}" type="email" name="contact[email]" pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$" title="{{ 'general.meta.email_format' | t }}" class="Form__Input" aria-label="{{ 'sections.newsletter.input' | t }}" placeholder="{{ 'sections.newsletter.input' | t }}" required>
                            <label class="VisuallyHidden" for="NewletterFormEmail--{{ section.id }}-{{ block.id }}">{{ 'sections.newsletter.input' | t }}</label>
                          </div>
                          <div class="Form__Item Newsletter__SubmitWrapper">
                            <button type="submit" class="Button Form__Submit">{{ 'sections.newsletter.submit' | t }}</button>
                          </div>
                        </div>
                      {%- endif -%}
                  {%- endform -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
        
      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Newsletter",
  "disabled_on": {
    "groups": [
      "header"
    ]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Customers who subscribe will have their email address added to the \"accepts marketing\" [customer list](/admin/customers?query=&accepts_marketing=1)."
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        {
          "value": "Small",
          "label": "Small"
        },
        {
          "value": "Medium",
          "label": "Medium"
        },
        {
          "value": "Large",
          "label": "Large"
        }
      ],
      "default": "Medium"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        {
          "value": "middleLeft",
          "label": "Left"
        },
        {
          "value": "middleCenter",
          "label": "Center"
        },
        {
          "value": "middleRight",
          "label": "Right"
        }
      ],
      "default": "middleCenter"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#435161"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Subscribe to our emails"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Color",
          "default": "#ffffff"
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Size",
          "options": [
            {
              "value": "DisplaySmall",
              "label": "Small"
            },
            {
              "value": "DisplayMedium",
              "label": "Medium"
            },
            {
              "value": "DisplayLarge",
              "label": "Large"
            }
          ],
          "default": "DisplayMedium"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subeading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Be the first to know about new collections and exclusive offers.</p>"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "email_form",
      "name": "Email form",
      "limit": 1,
      "settings": [
        {
          "type": "color",
          "id": "button_label_color",
          "label": "Button label color",
          "default": "#000"
        },
        {
          "type": "color",
          "id": "button_background_color",
          "label": "Button background color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "background_image",
      "name": "Background image",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "1600 x 800px .jpg recommended."
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Image overlay opacity",
          "info": "This can improve text visibility.",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 39
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "settings": {
      },
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "description"
        },
        {
          "type": "email_form"
        },
        {
          "type": "background_image"
        }
      ]
    }
  ]
}
{% endschema %}