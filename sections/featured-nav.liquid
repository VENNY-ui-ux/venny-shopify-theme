{%- if section.settings.layout_mode == 'carousel' -%}
  {{ 'component-carousel.css' | asset_url | stylesheet_tag }}
{%- endif -%}
{{ 'section-featured-nav.css' | asset_url | stylesheet_tag }}

<script src="{{ 'section-featured-nav.js' | asset_url }}" defer="defer"></script>
  
{%- if section.settings.layout_mode == 'carousel' -%}
  {%- capture carousel_options -%}
    {
      "freeMode": true,
      "slidesPerView": "auto",
      "navigation": {
        "enabled": false,
        "nextEl": ".Carousel__NavNext",
        "prevEl": ".Carousel__NavPrev"
      },
      "breakpoints": {
        "640": {
          "slidesPerView": "auto",
          "freeMode": false,
          "navigation": {
            "enabled": true,
            "nextEl": ".Carousel__NavNext",
            "prevEl": ".Carousel__NavPrev"
          }
        }
      }
    }
  {%- endcapture -%}
{%- endif -%}

{%- capture section_settings -%}
  {
    "layout": {{ section.settings.layout_mode | json }},
    "animationType": {{ section.settings.animation_type | json }}
  }
{%- endcapture -%}

{%- assign desktop_items_per_row = section.settings.grid_desktop_items_per_row | times: 1 -%}
{%- assign mobile_items_per_row  = section.settings.grid_mobile_items_per_row | times: 1 -%}
{%- assign tablet_items_per_row = desktop_items_per_row | divided_by: 1.5 | floor | at_least: 2 -%}

{%- assign nav_count = 0 -%}

<section-featured-nav class="Container Container--specialSpacingFirstSection {% if section.settings.section_width == 'full_width' %}Container--fluid{% endif %} Container--{{ section.settings.section_spacing }} FeaturedNav" data-section-id="{{ section.id }}" data-section-settings='{{ section_settings }}'>
  
    {%- for block in section.blocks -%}
        {%- case block.type -%}
            {%- when 'nav_item' -%}
                {%- assign nav_count = nav_count | plus: 1 -%}
            {%- when 'section_header' -%}
                <header class="SectionHeader SectionHeader--{{ block.settings.header_align }}"  {{ block.shopify_attributes }}>
                    <div class="SectionHeader__Text">
                        {%- if block.settings.heading != blank -%}
                            <h2 class="SectionHeader__Heading CustomSize {{ block.settings.heading_font_size }}">{{ block.settings.heading }}</h2>
                        {%- endif -%}
        
                        {%- if block.settings.subheading != blank -%}
                            <div class="SectionHeader__Subheading TextMuted">{{ block.settings.subheading }} </div>
                        {%- endif -%}
                    </div>
                </header>
        {%- endcase -%}
    {%- endfor -%}
  
      <div class="SectionBody FeaturedNav__Body Animate {% if section.settings.animation_type == 'staggering' and section.settings.layout_mode == 'grid' %}Animate--staggering{% endif %}"
        style="--tg-sys-section-featured-nav-image-border-radius: {{ section.settings.corner_radius }}px;">
        {%- if nav_count > 0 -%}
          {%- if section.settings.layout_mode == 'grid' -%}
            <div class="NavCardList NavCardList--grid Grid">
                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'nav_item' -%}
                            <div class="Grid__Item 1/{{ mobile_items_per_row }}--small 1/{{ tablet_items_per_row }}--medium-up 1/{{ desktop_items_per_row }}--large">
                                {% render 'nav-card', block: block %}
                            </div>
                        {%- endcase -%}
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="NavCardList NavCardList--carousel Carousel" data-carousel-config='{{ carousel_options }}'>
              <div class="CarouselWrapper">
                {%- for block in section.blocks -%}
                  {%- case block.type -%}
                    {%- when 'nav_item' -%}
                        <div class="Carousel__Item 1/{{ mobile_items_per_row }}--small 1/{{ tablet_items_per_row }}--medium-up 1/{{ desktop_items_per_row }}--large">
                            {% render 'nav-card', block: block %}
                        </div>
                    {%- endcase -%}
                {%- endfor -%}
              </div>
              <div class="Carousel__NavPrev">
                {%- render 'icons', icon: 'nav-right' -%}
              </div>
              <div class="Carousel__NavNext">
                {%- render 'icons', icon: 'nav-right' -%}
              </div>
            </div>
          {%- endif -%}
        {%- else -%}
          {%- if section.settings.layout_mode == 'grid' -%}
            <div class="NavCardList NavCardList--grid Grid">
              {%- for i in (1..desktop_items_per_row) -%}
                <div class="Grid__Item 1/{{ mobile_items_per_row }}--small 1/{{ tablet_items_per_row }}--medium-up 1/{{ desktop_items_per_row }}--large">
                  {% render 'nav-card-placeholder' %}
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
             <div class="NavCardList NavCardList--carousel Carousel" data-carousel-config='{{ carousel_options }}'>
              <div class="CarouselWrapper">
                {%- for i in (1..desktop_items_per_row) -%}
                  <div class="Carousel__Item 1/{{ mobile_items_per_row }}--small 1/{{ tablet_items_per_row }}--medium-up 1/{{ desktop_items_per_row }}--large">
                    {% render 'nav-card-placeholder' %}
                  </div>
                {%- endfor -%}
              </div>
              <div class="Carousel__NavPrev">
                {%- render 'icons', icon: 'nav-right' -%}
              </div>
              <div class="Carousel__NavNext">
                {%- render 'icons', icon: 'nav-right' -%}
              </div>
             </div>
          {%- endif -%}

        {%- endif -%}
  
    </div>
  
</section-featured-nav>

{% schema %}
{
  "name": "Featured nav",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "default",
          "label": "Grid"
        },
        {
          "value": "full_width",
          "label": "Full width"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "Section spacing",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "spacingSmall",
          "label": "Small"
        },
        {
          "value": "spacingMedium",
          "label": "Medium"
        },
        {
          "value": "spacingLarge",
          "label": "Large"
        }
      ],
      "default": "spacingMedium"
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "carousel",
          "label": "Carousel"
        }
      ],
      "default": "carousel"
    },
    {
      "type": "select",
      "id": "animation_type",
      "label": "Animation type",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "staggering",
          "label": "Staggering"
        }
      ],
      "default": "staggering",
      "info": "Visible when the ‘Layout’ setting is set to Grid."
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "min": 2,
      "max": 12,
      "step": 1,
      "id": "grid_desktop_items_per_row",
      "label": "Number of columns on desktop",
      "default": 8
    },
    {
      "type": "select",
      "id": "grid_mobile_items_per_row",
      "label": "Number of columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2",
      "info": "Visible when the ‘Layout’ setting is set to Grid."
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 400,
      "step": 4,
      "unit": "px",
      "label": "Image corner radius",
      "default": 200
    },
    {
      "type": "select",
      "id": "featured_image_size",
      "label": "Image ratio",
      "options": [
        {
          "value": "natural",
          "label": "Adapt to image"
        },
        {
          "value": "2x3",
          "label": "2:3"
        },
        {
          "value": "3x4",
          "label": "3:4"
        },
        {
          "value": "1x1",
          "label": "1:1"
        },
        {
          "value": "4x3",
          "label": "4:3"
        },
        {
          "value": "16x9",
          "label": "16:9"
        },
        {
          "value": "21x9",
          "label": "21:9"
        }
      ],
      "default": "natural"
    }
  ],
  "blocks": [
    {
      "type": "section_header",
      "name": "Section header",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Trending collections"
        },
        {
          "type": "select",
          "id": "header_align",
          "label": "Header alignment",
          "options": [
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "left",
              "label": "Left"
            }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Heading size",
          "options": [
            {
              "value": "HeadlineSmall",
              "label": "Small"
            },
            {
              "value": "HeadlineMedium",
              "label": "Medium"
            },
            {
              "value": "HeadlineLarge",
              "label": "Large"
            }
          ],
          "default": "HeadlineMedium"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        }
      ]
    },
    {
      "type": "nav_item",
      "name": "Nav item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Heading size",
          "options": [
            {
              "value": "TitleSmall",
              "label": "Small"
            },
            {
              "value": "TitleMedium",
              "label": "Medium"
            },
            {
              "value": "TitleLarge",
              "label": "Large"
            }
          ],
          "default": "TitleSmall"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subeading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured nav",
      "blocks": [
        {
          "type": "nav_item"
        },
        {
          "type": "nav_item"
        },
        {
          "type": "nav_item"
        },
        {
          "type": "nav_item"
        },
        {
          "type": "nav_item"
        },
        {
          "type": "nav_item"
        },
        {
          "type": "nav_item"
        },
        {
          "type": "nav_item"
        }
      ]
    }
  ]
}
{% endschema %}