{%- if section.settings.show_popup -%}
  {%- unless request.page_type == 'captcha' or section.settings.show_only_on_index and template != 'index' -%}
    {%- unless section.settings.show_only_for_visitors and customer -%}
      {{ 'section-newsletter-popup.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'section-newsletter-popup.js' | asset_url }}" defer="defer"></script>

      <style>
        {%- if section.settings.close_icon_color != blank and section.settings.close_icon_color != 'rgba(0,0,0,0)' -%}
          @media screen and (min-width: 641px) {
            #section-{{ section.id }} .NewsletterPopup__Close svg{
              color: {{ section.settings.close_icon_color }};
            }
          }
        {%- endif -%}
      
        {%- if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' -%}
          #section-{{ section.id }} .Modal__Content {
            color: {{ section.settings.text_color }};
          }
      
          #section-{{ section.id }} .Modal__Content a {
            color: {{ section.settings.text_color }};
            text-decoration-color:  {{ section.settings.text_color }};
          }

          #section-{{ section.id }} .Button--text {
            color: {{ section.settings.text_color }};
          }
      
          @media screen and (max-width: 640px) {
            #section-{{ section.id }} .NewsletterPopup__Close svg{
              color: {{ section.settings.text_color }};
            }
          }
      
          #section-{{ section.id }} .NewsletterPopup__Social svg{
            fill: {{ section.settings.text_color }};
          }
      
          #section-{{ section.id }} .Form--newsletterPopup .Form__Input,
          #section-{{ section.id }} .Form--newsletterPopup .Form__Input::placeholder{
            color: {{ section.settings.text_color }};
          }
      
          #section-{{ section.id }} .Form--newsletterPopup .Form__Input {
            border-color: {{ section.settings.text_color }};
            background: initial;
          }
        {%- endif -%}
      
        {%- if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' -%}
          #section-{{ section.id }} .Modal__Content {
            background-color: {{ section.settings.background_color }};
          }
        {%- endif -%}
      
        {%- if section.settings.button_label_color != blank and section.settings.button_label_color != 'rgba(0,0,0,0)' -%}
          #section-{{ section.id }} .Form--newsletterPopup .Form__Submit {
            color: {{ section.settings.button_label_color }};
          }
        {%- endif -%}
      
        {%- if section.settings.button_background_color != blank and section.settings.button_background_color != 'rgba(0,0,0,0)' -%}
          #section-{{ section.id }} .Form--newsletterPopup .Form__Submit {
            border-color: {{ section.settings.button_background_color }};
            background-color:{{ section.settings.button_background_color }};
          }
          
        {%- endif -%}
        
      </style>      

      {% capture section_settings %}
        {
          "apparitionDelay": {{ section.settings.apparition_delay | json }},
          "showOnlyOnce": {{ section.settings.show_only_once | json }}
        }
      {% endcapture %}

      {%- capture popup_image -%}
        {%- if section.settings.image != blank -%}
          <div class="NewsletterPopup__ImageWrapper">
            <div class="Ratio" style="--tg-aspect-ratio: {{ section.settings.image.aspect_ratio }} ;">
              {%- capture tg_sizes -%}(min-width: 641px) 380px, 100vw{%- endcapture -%}
              {{ section.settings.image | image_url: width: 1500 | image_tag:
                sizes: tg_sizes,
                widths: '360, 535, 750, 1070, 1500',
                class: 'NewsletterPopup__Image'
              }}
            </div>
          </div>
        {%- endif -%}
      {%- endcapture -%}

      {%- capture popup_content -%}
        <div class="NewsletterPopup__ContentWrapper">
          <div class="NewsletterPopup__Content">
            <button class="Button Button--icon NewsletterPopup__Close" data-tg-dismiss="Modal" aria-label="{{ 'general.modal.close' | t }}">{%- render 'icons', icon: 'close' -%}</button>

            {%- if section.settings.heading != blank -%} 
              <h2 class="NewsletterPopup__Heading">{{ section.settings.heading | escape }}</h2>
            {%- endif -%}

            {%- if section.settings.description != blank -%}
              <div class="NewsletterPopup__Description RTE">
                {{ section.settings.description }}
              </div>
            {%- endif -%}

            {%- form 'customer', id: 'NewsletterPopup', class: 'Form Form--newsletterPopup' -%}
              {%- if form.posted_successfully? -%}
                <p class="Alert Alert--success">{{ 'sections.newsletter_popup.success' | t }}</p>
                <script>
                  localStorage.setItem("newsletterPopupFilled", "true");
                </script>
              {%- else -%}
                <input type="hidden" name="contact[tags]" value="newsletter">

                <input type="email" name="contact[email]" pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$" title="{{ 'general.meta.email_format' | t }}" class="Form__Input" aria-label="{{ 'sections.newsletter_popup.input' | t }}" placeholder="{{ 'sections.newsletter_popup.input' | t }}" required>
                <button class="Button Button--full Button--primary Form__Submit" type="submit">{{ 'sections.newsletter_popup.submit' | t }}</button>
                <button class="Button Button--text" id="NewsletterPopupNo" type="button">{{ 'sections.newsletter_popup.no_thanks' | t }}</button>
              {%- endif -%}
            {%- endform -%}

            {%- if section.settings.show_social_media -%}
              {%- render 'social-media', class: 'NewsletterPopup__Social' -%}
            {%- endif -%}
          </div>
        </div>
      {%- endcapture -%}

      <section-newsletter-popup id="section-{{ section.id }}" class="Modal Fade NewsletterPopup {% if section.settings.image != blank %}NewsletterPopup--withImage NewsletterPopup--image{{- section.settings.image_position }}{% endif %}" data-section-settings='{{ section_settings }}' aria-hidden="true" tabindex="-1">
        <div class="Modal__Dialog Modal__Dialog--centered">
          
          <div class="Modal__Content">
            <div class="Modal__Body">
              {{- popup_image -}}
              {{- popup_content -}} 
            </div>
          </div>
        </div>
      </section-newsletter-popup>
    {%- endunless -%}

  {%- endunless -%}
{%- endif -%}


{% schema %}
{
  "name": "Newsletter popup",
  "class": "shopify-section--newsletter-popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_popup",
      "label": "Enable newsletter popup",
      "default": false,
      "info": "Customers who subscribe will have their email address added to the \"accepts marketing\" [customer list](/admin/customers?query=&accepts_marketing=1)."
    },
    {
      "type": "range",
      "id": "apparition_delay",
      "min": 0,
      "max": 15,
      "step": 1,
      "unit": "sec",
      "label": "Delay until the popup appears",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_only_on_index",
      "label": "Show only on home page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_only_for_visitors",
      "label": "Show only for visitors",
      "info": "Customers who have created an account on your shop won't see it.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_only_once",
      "label": "Show only once per customer",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social_media",
      "label": "Show social media",
      "info": "Make sure to have properly configured your social media in the theme settings.",
      "default": true
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "800 x 1200px .png recommended, hide on mobile view"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "Left",
          "label": "Left"
        },
        {
          "value": "Right",
          "label": "Right"
        }
      ],
      "default": "Right"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe to our emails"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Text",
      "default": "<p>Be the first to know about new collections and exclusive offers.</p>"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background color"
    },
    {
      "type": "color",
      "id": "button_label_color",
      "label": "Button label color"
    },
    {
      "type": "color",
      "id": "close_icon_color",
      "label": "Close icon color",
      "info": "Visible on desktop."
    }
  ]
}
{% endschema %}