{{ 'component-text-on-image.css' | asset_url | stylesheet_tag }}
{{ 'section-vertical-accordion.css' | asset_url | stylesheet_tag }}

<style>
  @media screen and (min-width: 641px) {
    #section-{{ section.id }} .TextOnImage{
      {% if section.settings.section_width == 'full_width' %}
        width: calc( 100vw - var(--tg-container-gutter-x) * 6 - {{ section.blocks.size | minus: 1 | times: 4 | default: 1 }}rem );
      {% elsif section.settings.section_width ==  'full_width_no_gap' %}
        width: calc( 100vw - {{ section.blocks.size | minus: 1 | times: 4 | default: 1 }}rem );
      {% else %}
        width: calc( min(100vw, var(--tg-container-max-width, 1280px)) - var(--tg-container-gutter-x) * 6 - {{ section.blocks.size | minus: 1 | times: 4 | default: 1 }}rem );
      {% endif %}
    }
  }
  {% for block in section.blocks %}
    {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}
      #section-{{ section.id }} #Accordion{{ block.id }} .SectionHeader__Heading,
      #section-{{ section.id }} #Accordion{{ block.id }} .SectionHeader__Subheading,
      #section-{{ section.id }} #Accordion{{ block.id }} .SectionHeader__Description,
      #section-{{ section.id }} #Accordion{{ block.id }} .SectionHeader__Description a,
      #section-{{ section.id }} #Accordion{{ block.id }} .Button--outline,
      #section-{{ section.id }} #Accordion{{ block.id }} .Button--underline,
      #section-{{ section.id }} #Accordion{{ block.id }} .VerticalAccordion__Button{
        color: {{ block.settings.text_color }};
      }

      #section-{{ section.id }} #Accordion{{ block.id }} .SectionHeader__Description a{
        text-decoration-color: {{ block.settings.text_color }};
      }

      #section-{{ section.id }} #Accordion{{ block.id }} .Button--outline{
        border-color: {{ block.settings.text_color }};
        background-color: transparent;
      }
    {% endif %}

  {% endfor %}
</style>

{% liquid 
  assign section_has_image = false
  if section.settings.accordion_height == 'adaptImage'
    if section.blocks.first.settings.image != blank
      assign section_has_image = true
      if section.blocks.first.settings.image != blank 
        assign section_image_ratio = section.blocks.first.settings.image.aspect_ratio
      endif
    endif 
  endif

  assign animation_image_loading_tag = 'div'
  assign animation_image_loading_class = 'VerticalAccordion__Image TextOnImage__Image'
  if settings.animation_image_loading == 'circle_icon'
    assign animation_image_loading_tag = 'feature-img'
    assign animation_image_loading_class = 'VerticalAccordion__Image TextOnImage__Image Image--withLoader'
  endif
-%}

<section-vertical-accordion id="section-{{ section.id }}" class="Container--relative Container Container--specialSpacingFirstSection VerticalAccordion VerticalAccordion--heading{{ section.settings.vertical_heading_position }} 
  {% if section.settings.section_width == 'full_width' %}Container--fluid Container--spacingContainerGutter Container--specialSpacingLastSection{% elsif section.settings.section_width ==  'full_width_no_gap' %}Container--fluid Container--noGutter Container--specialSpacingLastSection{% else %}Container--{{ section.settings.section_spacing }}{% endif %}" data-section-id="{{ section.id }}">
 
  <div class="VerticalAccordion__Wrapper">
      {%- for block in section.blocks -%}
        {%- capture accordion_block_content -%}
          {%- liquid 
            assign fetch_priority = 'auto'
            assign lazy_load = 'lazy'

            if section.index == 1 and forloop.first and section.location != 'footer'
              assign fetch_priority = 'high'
              assign lazy_load = 'eager'
            endif
          -%}

          {%- if block.settings.image -%}
            <{{- animation_image_loading_tag }} class="TextOnImage__ImageWrapper Ratio VerticalAccordion__ImageWrapper {% if block.settings.overlay_opacity > 0 %}ImageOverlay{% endif %}">
              {{ block.settings.image | image_url: width: 3840 | image_tag:
                sizes: '100vw',
                widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                class: animation_image_loading_class,
                loading: lazy_load,
                fetchpriority: fetch_priority
              }}
              {%- if settings.animation_image_loading != 'none' -%}
                <span class="Image--loader"></span>
              {%- endif -%}
            </{{- animation_image_loading_tag }}>
          {%- else -%}
            <div class="TextOnImage__ImageWrapper Ratio {% if block.settings.overlay_opacity > 0 %}ImageOverlay{% endif %}" style = "--tg-aspect-ratio: 1.5;">
              {%- capture placeholder -%}{% cycle 'lifestyle-1', 'lifestyle-2' %}{%- endcapture -%}
              {{ placeholder | placeholder_svg_tag: 'TextOnImage__Image VerticalAccordion__Image SvgPlaceholder' }}
            </div>
          {%- endif -%}

          {%- capture accordion_content -%}
            {%- if block.settings.subheading != blank -%}
              <h3 class="SectionHeader__Subheading">{{ block.settings.subheading }}</h3>
            {%- endif -%}

            {%- if block.settings.heading != blank -%} 
              <h2 class="SectionHeader__Heading CustomSize {{ block.settings.heading_font_size }}">{{ block.settings.heading }}</h2>
            {%- endif -%}

            {%- if block.settings.description != blank -%} 
              <div class="SectionHeader__Description RTE">{{ block.settings.description }}</div>
            {%- endif -%}

            {%- if block.settings.button_1_label != blank and block.settings.button_2_label != blank -%}
              {%- assign has_two_buttons = true -%}
            {%- else -%}
              {%- assign has_two_buttons = false -%}
            {%- endif -%}

            {%- if block.settings.button_1_label != blank or block.settings.button_2_label != blank -%}
              <div class="SectionHeader__ButtonWrapper">
                <div class="ButtonGroup {% if has_two_buttons %}ButtonGroup--smallSize{% endif %}">
                  {%- if block.settings.button_1_label != blank -%}
                    <a href="{{ block.settings.button_1_link }}" class="Button Button--{{ block.settings.button_1_style }}">{{ block.settings.button_1_label | escape }}</a>
                  {%- endif -%}

                  {%- if block.settings.button_2_label != blank -%}
                    <a href="{{ block.settings.button_2_link }}" class="Button Button--{{ block.settings.button_2_style }}">{{ block.settings.button_2_label | escape }}</a>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endcapture -%}

          {%- if block.settings.vertical_heading != blank -%}
            <button class="VerticalAccordion__Button VerticalAccordion__Button--verticalAlign{{ section.settings.vertical_heading_alignment }} CustomSize {{ section.settings.vertical_heading_font_size }}">
              {{ block.settings.vertical_heading }}
            </button>
          {%- endif -%} 
          <div class="TextOnImage__Content">
            <div class="TextOnImage__ContentInner">
              <div class="SectionHeader SectionHeader--noOutline">
                {{ accordion_content }}
              </div>
            </div>

            {%- if block.settings.button_1_label == blank and block.settings.button_2_label == blank and block.settings.image_link != blank -%}
              <a class="StretchedLink" href="{{ block.settings.image_link }}"></a>
            {%- endif -%} 

          </div>
        {%- endcapture -%}
        
          <div id="Accordion{{ block.id }}" 
            {% if section.settings.vertical_heading_position == 'Left' %}style="order: {{ section.blocks.size | minus: forloop.index0 }}"{% endif %}
             class="VerticalAccordion__Item VerticalAccordion__Item--{{ block.id }} {% if forloop.first %}Active{% endif %}" {{ block.shopify_attributes }}>
            <div class="TextOnImage TextOnImage--{{ block.settings.content_position }} TextOnImage--{{ section.settings.accordion_height }}"
              style="{% if section_has_image %}--tg-component-text-on-image-image-ratio-mobile: {{ section_image_ratio }};--tg-component-text-on-image-image-ratio: {{ section_image_ratio }};
              {% elsif section.settings.accordion_height == 'adaptImage' %} --tg-component-text-on-image-image-ratio-mobile: 1.1; --tg-component-text-on-image-image-ratio: 2.2;
            {% endif %}">
              {{- accordion_block_content -}}

              {%- if block.settings.image_link != blank -%}
                <a class="StretchedLink" href="{{ block.settings.image_link }}"></a>
              {%- endif -%}

            </div>
          </div>
        
        
      {%- endfor -%}

  </div>
  
</section-vertical-accordion>

<script src="{{ 'section-vertical-accordion.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
