{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}

<section class="Container Container--specialSpacingFirstSection Container--noGutter Container--fluid FeaturedBlog FeaturedBlog--{{ section.settings.layout_mobile }} {% if section.settings.background != blank and section.settings.background != 'rgba(0,0,0,0)' %}Container--specialSpacingLastSection Container--{{ section.settings.section_spacing }}Padding{% else %}Container--{{ section.settings.section_spacing }}{% endif %} FeaturedBlog" id="section-{{ section.id }}" data-section-id="{{ section.id }}"
  style="{% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}--tg-featured-blog-text-color: {{ section.settings.text_color }};--tg-section-header-text-color: {{ section.settings.text_color }};{% endif %}
  {% if section.settings.background != blank and section.settings.background != 'rgba(0,0,0,0)' %}--tg-featured-blog-background-color: {{ section.settings.background }};{% endif %}
  ">
  <div class="Container {% if section.settings.section_width == 'full_width' %}Container--fluid{% endif %}">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'section_header' -%}
          <header class="SectionHeader SectionHeader--{{ block.settings.header_align }}"  {{ block.shopify_attributes }}>
            <div class="SectionHeader__Text">
              {%- if block.settings.heading != blank -%}
                  <h2 class="SectionHeader__Heading CustomSize {{ block.settings.heading_font_size }}">{{ block.settings.heading }}</h2>
              {%- endif -%}

              {%- if block.settings.subheading != blank -%}
                  <div class="SectionHeader__Subheading TextMuted">{{ block.settings.subheading }} </div>
              {%- endif -%}
            </div>

            {%- if block.settings.header_align == 'left' and block.settings.button_label != blank -%} 
              <div class="SectionHeader__Button"> 
                <a href="{{ block.settings.button_link }}" class="SectionHeader__Button Button Button--outline">{{ block.settings.button_label | escape }}</a>        
              </div>
            {%- endif -%}

            {%- if block.settings.header_align == 'center' and block.settings.button_label != blank -%} 
              {%- capture section_footer -%}
                <footer class="SectionFooter TextCenter">
                    <a class="SectionFooter__Button Button Button--outline" href="{{ block.settings.button_link }}">{{ block.settings.button_label | escape }}</a>
                </footer>
              {%- endcapture -%}
            {%- endif -%}
          </header>
      {%- endcase -%}
    {%- endfor -%}

    {%- liquid
      assign show_placeholders = true 
      assign card_mobile_items_per_row = 1
      if section.settings.layout_mobile == 'horizontal'
        assign card_mobile_items_per_row = 1.136
      endif
    -%}

    <div class="SectionBody FeaturedBlog__Body">
      {%- for block in section.blocks -%}
     
        {%- case block.type -%}
          {%- when 'article' -%}
              <div class="Grid" {{ block.shopify_attributes }}>
              {%- liquid
                assign item_count = 0
                for i in (1..4)
                  assign article_option = 'article_' | append: i
                  assign article = articles[block.settings[article_option]]

                  unless article == empty
                    assign item_count = item_count | plus: 1
                  endunless
                endfor 
              -%}

              {%- for i in (1..4) -%}
                {%- assign article_option = 'article_' | append: i -%}
                {%- assign article = articles[block.settings[article_option]] -%}

                {%- unless article == empty -%}
                  <div class="Grid__Item 1/{{ item_count }}--large">
                    {%- render 'article-card', block: block, article: article, card_desktop_items_per_row: item_count, card_mobile_items_per_row: card_mobile_items_per_row -%}
                  </div>

                  {%- assign show_placeholders = false -%}
                {%- endunless -%}
              {%- endfor -%}
            </div>

          {%- when 'blog' -%}
            <div class="Grid" {{ block.shopify_attributes }}>
              {%- liquid
                assign blog = block.settings.blog
                assign item_count = block.settings.grid_items_count
              -%}

              {%- for article in blog.articles limit: item_count -%}
                <div class="Grid__Item 1/{{ item_count }}--large">
                  {%- render 'article-card', block: block, article: article, card_desktop_items_per_row: item_count, card_mobile_items_per_row: card_mobile_items_per_row -%}
                </div>

                {%- assign show_placeholders = false -%}
              {%- endfor -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- if show_placeholders -%}
        <div class="Grid">
          {%- for i in (1..3) -%}
            <div class="Grid__Item 1/3--medium-up">
              {%- render 'article-card-placeholder' -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
    
    {{ section_footer }}
  </div>
</section>

{% schema %}
{
