{{ 'component-text-on-image.css' | asset_url | stylesheet_tag }}
{{ 'section-collage.css' | asset_url | stylesheet_tag }}

<section id="section-{{ section.id }}" class="Container Container--specialSpacingFirstSection {% if section.settings.section_width == 'full_width' %}Container--fluid Container--spacingContainerGutter Container--specialSpacingLastSection{% elsif section.settings.section_width ==  'full_width_no_gap' %}Container--fluid Container--noGutter Container--specialSpacingLastSection{% else %}Container--{{ section.settings.section_spacing }}{% endif %} 
Collage Collage--{{ section.settings.collage_design }} Collage--{{ section.settings.collage_design_mobile }} {% if section.settings.add_gap %}Collage--spaced{% endif %}" 
data-section-id="{{ section.id }}">
  {%- assign has_item_block = false -%}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'image' -%}
        {%- assign has_item_block = true -%}

      {%- when 'section_header' -%}
        <header class="SectionHeader SectionHeader--{{ block.settings.header_align }}"  {{ block.shopify_attributes }}>
          <div class="SectionHeader__Text">
            {%- if block.settings.heading != blank -%}
                <h2 class="SectionHeader__Heading CustomSize {{ block.settings.heading_font_size }}">{{ block.settings.heading }}</h2>
            {%- endif -%}

            {%- if block.settings.subheading != blank -%}
                <div class="SectionHeader__Subheading TextMuted">{{ block.settings.subheading }} </div>
            {%- endif -%}
          </div>

          {%- if block.settings.header_align == 'left' and block.settings.button_label != blank -%} 
            <div class="SectionHeader__Button"> 
              <a href="{{ block.settings.button_link }}" class="SectionHeader__Button Button Button--outline">{{ block.settings.button_label | escape }}</a>        
            </div>
          {%- endif -%}

          {%- if block.settings.header_align == 'center' and block.settings.button_label != blank -%} 
            {%- capture section_footer -%}
              <footer class="SectionFooter Collage__Footer TextCenter">
                  <a class="SectionFooter__Button Button Button--outline" href="{{ block.settings.button_link }}">{{ block.settings.button_label | escape }}</a>
              </footer>
            {%- endcapture -%}
          {%- endif -%}
        </header>
    {%- endcase -%}
  {%- endfor -%}

  <div class="SectionBody Collage__Body">
    {%- if has_item_block -%}
      {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'image' -%}
              <div class="CollageItem" {{ block.shopify_attributes }}>
                  {%- render 'collage-card-image', block: block -%}
              </div>
          {%- endcase -%}
      {%- endfor -%}
    {%- else -%} 
      {%- for i in (1..3) -%}
        <div class="CollageItem">
          {%- render 'collage-card-image-placeholder' -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {{ section_footer }}
   
</section>

