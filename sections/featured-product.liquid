          "default": "HeadlineSmall"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        }
      ]
    },
    {
      "type": "@app"
    },
    {
      "type": "custom_liquid",
      "name": "Custom Liquid",
      "settings": [
